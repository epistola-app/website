---
import Faqs from "../components/faqs.astro";
import Join from "../components/join.astro";
import Layout from "../components/layout.astro";
import PriceTiers from "../components/price-tiers.astro";
---

<Layout>
  <section
    class="pt-32 pb-20 bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1
          class="text-5xl md:text-6xl font-bold mb-6 text-gray-900 dark:text-white"
        >
          Simple, Transparent
          <span class="block mt-2 text-accent-teal"> Pricing </span>
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300">
          Choose the plan that's right for you. All plans include our core
          features.
        </p>
      </div>
    </div>
  </section>
  <PriceTiers />
  <Faqs />
  <Join />
</Layout>

