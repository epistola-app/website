---
import Layout from "../components/layout.astro";
import Title from "../components/ui/title.astro";
import { EMAILS } from "../lib/URL-helpers";
---

<Layout
  title="Epistola · Terms"
  description="Usage terms for the Epistola website, demo environment, and commercial support offerings."
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4">
      <p class="eyebrow">Terms</p>
      <Title level={1} class="mt-4"> Terms of use </Title>
      <div class="mt-10 space-y-10 text-[var(--color-peach-paper-copy)]">
        <section>
          <Title level={2}>Open-source usage</Title>
          <p class="mt-3">
            Epistola’s source code is licensed under the AGPL. You are free to self-host, modify, and redistribute the
            software under that license. Contributions are accepted via GitHub.
          </p>
        </section>
        <section>
          <Title level={2}>Demo environment</Title>
          <p class="mt-3">
            The public demo is provided “as is.” We may reset, limit, or suspend access if the environment is misused.
            Do not store sensitive information in the demo instance.
          </p>
        </section>
        <section>
          <Title level={2}>Commercial support</Title>
          <p class="mt-3">
            Support and managed hosting plans are governed by separate service agreements. Those agreements outline
            SLAs, pricing, and acceptable use.
          </p>
        </section>
        <section>
          <Title level={2}>Liability</Title>
          <p class="mt-3">
            To the fullest extent permitted by law, Epistola and its contributors are not liable for any damages arising
            from the use of the open-source software, the demo environment, or third-party integrations.
          </p>
        </section>
        <section>
          <Title level={2}>Contact</Title>
          <p class="mt-3">
            For contractual questions, reach out to <a
              class="underline hover:text-[var(--color-peach-paper-accent)]"
              href={EMAILS.HELLO}>hello@epistola.app</a
            >.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
