---
import Layout from "../components/layout.astro";
import Button from "../components/ui/button.astro";
import Card from "../components/ui/card.astro";
import Title from "../components/ui/title.astro";
import { BookOpen } from "@lucide/astro";
---

<Layout>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">Documentation</p>
      <Title level={1} class="mt-6">Documentation is coming</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        We're working on comprehensive guides, API references, and integration tutorials for Epistola.
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <Card variant="brand" radius="3xl" shadow="md" padding="lg" class="mx-auto max-w-2xl text-center">
        <BookOpen class="w-10 h-10 mx-auto text-[var(--color-peach-paper-accent)]" />
        <Title level={2} class="mt-4 text-xl">Stay tuned</Title>
        <p class="mt-2 text-[var(--color-peach-paper-copy)]">
          In the meantime, explore the demo environment to get a feel for how Epistola works.
        </p>
        <div class="mt-6">
          <Button href="/demo" variant="primary" size="md">Try demo</Button>
        </div>
      </Card>
    </div>
  </section>
</Layout>
