---
import Layout from "../../components/layout.astro";
import Card from "../../components/ui/card.astro";
import Title from "../../components/ui/title.astro";
import ContactForm from "../../components/contact-form.astro";
import { EMAILS } from "../../lib/URL-helpers";
import { Mail } from "@lucide/astro";
import { getStaticLocalePaths, t, type Locale } from "../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;
---

<Layout
  lang={lang}
  title={t(lang, "pages.contact.title")}
  description={t(lang, "pages.contact.description")}
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">{t(lang, "contact.page.eyebrow")}</p>
      <Title level={1} class="mt-6">{t(lang, "contact.page.title")}</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        {t(lang, "contact.page.description")}
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <Card variant="brand" radius="3xl" shadow="md" padding="lg" class="mx-auto max-w-2xl">
        <ContactForm lang={lang} />
      </Card>

      <div class="mx-auto max-w-2xl mt-8 text-center text-sm text-[var(--color-peach-paper-chip-text)]">
        <p class="flex items-center justify-center gap-2">
          <Mail class="w-4 h-4" />
          {t(lang, "contact.page.emailPrefix")}
          <a href={EMAILS.HELLO} class="text-[var(--color-peach-paper-accent)] hover:underline">
            sander@epistola.app
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
