---
import Layout from "../../components/layout.astro";
import Title from "../../components/ui/title.astro";
import { EMAILS } from "../../lib/URL-helpers";
import { getStaticLocalePaths, t, type Locale } from "../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;
---

<Layout
  lang={lang}
  title={t(lang, "pages.terms.title")}
  description={t(lang, "pages.terms.description")}
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4">
      <p class="eyebrow">{t(lang, "terms.eyebrow")}</p>
      <Title level={1} class="mt-4">{t(lang, "terms.title")}</Title>
      <div class="mt-10 space-y-10 text-[var(--color-peach-paper-copy)]">
        <section>
          <Title level={2}>{t(lang, "terms.section.0.title")}</Title>
          <p class="mt-3">
            {t(lang, "terms.section.0.body")}
          </p>
        </section>
        <section>
          <Title level={2}>{t(lang, "terms.section.1.title")}</Title>
          <p class="mt-3">
            {t(lang, "terms.section.1.body")}
          </p>
        </section>
        <section>
          <Title level={2}>{t(lang, "terms.section.2.title")}</Title>
          <p class="mt-3">
            {t(lang, "terms.section.2.body")}
          </p>
        </section>
        <section>
          <Title level={2}>{t(lang, "terms.section.3.title")}</Title>
          <p class="mt-3">
            {t(lang, "terms.section.3.body")}
          </p>
        </section>
        <section>
          <Title level={2}>{t(lang, "terms.section.4.title")}</Title>
          <p class="mt-3">
            {t(lang, "terms.section.4.body")}
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
