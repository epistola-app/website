---
import Layout from "../../components/layout.astro";
import Button from "../../components/ui/button.astro";
import Card from "../../components/ui/card.astro";
import Title from "../../components/ui/title.astro";
import { BookOpen } from "@lucide/astro";
import { getStaticLocalePaths, t, localePath, type Locale } from "../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;
---

<Layout
  lang={lang}
  title={t(lang, "pages.docs.title")}
  description={t(lang, "pages.docs.description")}
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">{t(lang, "docs.eyebrow")}</p>
      <Title level={1} class="mt-6">{t(lang, "docs.title")}</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        {t(lang, "docs.description")}
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <Card variant="brand" radius="3xl" shadow="md" padding="lg" class="mx-auto max-w-2xl text-center">
        <BookOpen class="w-10 h-10 mx-auto text-[var(--color-peach-paper-accent)]" />
        <Title level={2} class="mt-4 text-xl">{t(lang, "docs.card.title")}</Title>
        <p class="mt-2 text-[var(--color-peach-paper-copy)]">
          {t(lang, "docs.card.description")}
        </p>
        <div class="mt-6">
          <Button href={localePath(lang, "/demo")} variant="primary" size="md">{t(lang, "docs.card.cta")}</Button>
        </div>
      </Card>
    </div>
  </section>
</Layout>
