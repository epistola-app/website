---
import { getCollection } from "astro:content";
import Layout from "../../components/layout.astro";
import Title from "../../components/ui/title.astro";
import { getStaticLocalePaths, t, filterByLocale, type Locale } from "../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;

const allPages = await getCollection("pages");
const items = filterByLocale(allPages, lang, "legal").filter(i => i.data.page === "privacy");
const rendered = await Promise.all(
  items.map(async (item) => ({
    data: item.data,
    Content: (await item.render()).Content,
  }))
);
---

<Layout
  lang={lang}
  title={t(lang, "pages.privacy.title")}
  description={t(lang, "pages.privacy.description")}
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4">
      <p class="eyebrow">{t(lang, "privacy.eyebrow")}</p>
      <Title level={1} class="mt-4">{t(lang, "privacy.title")}</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        {t(lang, "privacy.intro")}
      </p>
      <div class="mt-12 space-y-10 text-[var(--color-peach-paper-copy)]">
        {rendered.map(({ data, Content }) => (
          <section>
            <Title level={2}>{data.title}</Title>
            <div class="mt-3">
              <Content />
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</Layout>
