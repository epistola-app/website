---
import Layout from "../../components/layout.astro";
import Hero from "../../components/hero.astro";
import HeroStats from "../../components/hero-stats.astro";
import TrustedBy from "../../components/trusted-by.astro";
import BuiltFor from "../../components/built-for.astro";
import EverythingYouNeed from "../../components/everything-you-need.astro";
import DocOpsArchitecture from "../../components/docops-architecture.astro";
import ArchitectureFlow from "../../components/architecture-flow.astro";
import TransformYourBusiness from "../../components/transform-your-business.astro";
import WhyUs from "../../components/why-us.astro";
import Stats from "../../components/stats.astro";
import Testimonials from "../../components/testimonials.astro";
import IntegrationsOverview from "../../components/integrations-overview.astro";
import IntroVideo from "../../components/intro-video.astro";
import HowItWorks from "../../components/how-it-works.astro";
import Faqs from "../../components/faqs.astro";
import Join from "../../components/join.astro";
import { getStaticLocalePaths, type Locale } from "../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;
---

<Layout lang={lang}>
  <!-- HOOK ZONE -->
  <Hero lang={lang} />
  <TrustedBy lang={lang} />
  <IntroVideo lang={lang} />

  <!-- WHAT & WHY ZONE -->
  <HowItWorks lang={lang} />
  <WhyUs lang={lang} />
  <TransformYourBusiness lang={lang} />

  <!-- PRODUCT ZONE -->
  <EverythingYouNeed lang={lang} />
  <BuiltFor lang={lang} />

  <!-- DEPTH ZONE -->
  <DocOpsArchitecture lang={lang} />
  <ArchitectureFlow lang={lang} />
  <IntegrationsOverview lang={lang} />

  <!-- PROOF ZONE -->
  <Stats lang={lang} />
  <Testimonials lang={lang} />
  <Faqs lang={lang} />

  <!-- ACTION ZONE -->
  <Join lang={lang} />
</Layout>
