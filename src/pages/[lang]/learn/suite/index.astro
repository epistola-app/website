---
import { getCollection } from "astro:content";
import Layout from "../../../../components/layout.astro";
import Title from "../../../../components/ui/title.astro";
import { getStaticLocalePaths, t, localePath, filterByLocale, type Locale } from "../../../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;

const allDocs = await getCollection("docs");
const localeDocs = filterByLocale(allDocs, lang);

const sections = [
  { key: "core-concepts" as const, docs: localeDocs.filter((d) => d.data.section === "core-concepts") },
  { key: "editor" as const, docs: localeDocs.filter((d) => d.data.section === "editor") },
  { key: "generation" as const, docs: localeDocs.filter((d) => d.data.section === "generation") },
  { key: "platform" as const, docs: localeDocs.filter((d) => d.data.section === "platform") },
];
---

<Layout
  lang={lang}
  title={t(lang, "pages.suite.title")}
  description={t(lang, "pages.suite.description")}
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">{t(lang, "suite.eyebrow")}</p>
      <Title level={1} class="mt-6">{t(lang, "suite.title")}</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        {t(lang, "suite.description")}
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl space-y-12">
        {sections.map((section) => (
          <div>
            <h2 class="mb-4 text-xs font-bold uppercase tracking-wider text-[var(--muted-text)] font-[family-name:var(--font-mono)]">
              {t(lang, `docs.section.${section.key}`)}
            </h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {section.docs.map((doc) => {
                const slug = doc.slug.replace(`${lang}/`, "");
                return (
                  <a
                    href={localePath(lang, `/learn/suite/${slug}`)}
                    class="group block rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] p-5 transition-colors hover:border-[var(--color-peach-paper-border-strong)] hover:bg-[var(--color-peach-paper-surface-soft)]"
                  >
                    <h3 class="font-semibold text-[var(--color-peach-paper-heading)] group-hover:text-[var(--color-peach-paper-accent)]">
                      {doc.data.title}
                    </h3>
                    <p class="mt-1 text-sm text-[var(--muted-text)]">
                      {doc.data.description}
                    </p>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
