---
import { getCollection } from "astro:content";
import Layout from "../../../../components/layout.astro";
import DocsPage from "../../../../components/docs/docs-page.astro";
import { LOCALES, stripLocalePrefix, t, type Locale } from "../../../../i18n";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return LOCALES.flatMap((lang) =>
    docs
      .filter((doc) => doc.slug.startsWith(`${lang}/`))
      .map((doc) => ({
        params: { lang, slug: stripLocalePrefix(doc.slug, lang) },
        props: { doc },
      }))
  );
}

const lang = Astro.params.lang as Locale;
const { doc } = Astro.props;
const { Content } = await doc.render();
---

<Layout
  lang={lang}
  title={`${doc.data.title} · ${t(lang, "suite.title")}`}
  description={doc.data.description}
>
  <DocsPage
    title={doc.data.title}
    description={doc.data.description}
    currentSlug={Astro.params.slug as string}
    lang={lang}
  >
    <Content />
  </DocsPage>
</Layout>
