---
import { getCollection } from "astro:content";
import Layout from "../../../components/layout.astro";
import Title from "../../../components/ui/title.astro";
import { getStaticLocalePaths, t, localePath, type Locale } from "../../../i18n";

export const getStaticPaths = getStaticLocalePaths;
const lang = Astro.params.lang as Locale;

const posts = await getCollection("blog");
const localePosts = posts.filter((post) => post.slug.startsWith(`${lang}/`));
const sortedPosts = localePosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateLocale = lang === "nl" ? "nl-NL" : "en-US";
function formatDate(date: Date): string {
  return date.toLocaleDateString(dateLocale, {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function postHref(slug: string): string {
  const localSlug = slug.replace(`${lang}/`, "");
  return localePath(lang, `/blog/${localSlug}`);
}
---

<Layout
  lang={lang}
  title={t(lang, "pages.blog.title")}
  description={t(lang, "pages.blog.description")}
>
  <section class="pt-32 pb-20 [background-image:var(--gradient-peach-paper-soft)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <Title level={1} class="mb-6 text-5xl font-bold md:text-6xl">{t(lang, "blog.title")}</Title>
        <p class="text-xl text-[var(--muted-text)]">{t(lang, "blog.subtitle")}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          sortedPosts.map((post) => (
            <article class="overflow-hidden rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] shadow-lg transition-shadow hover:shadow-xl">
              <a href={postHref(post.slug)}>
                {post.data.cover && (
                  <img src={post.data.cover} alt={post.data.title} class="h-48 w-full object-cover" loading="lazy" />
                )}
              </a>
              <div class="p-6">
                <div class="mb-2 text-sm text-[var(--color-peach-paper-chip-text)]">{formatDate(post.data.date)}</div>
                <Title level={2} class="mb-3 text-xl font-bold">
                  <a
                    href={postHref(post.slug)}
                    class="transition-colors hover:text-[var(--color-peach-paper-accent)]"
                  >
                    {post.data.title}
                  </a>
                </Title>
                <p class="mb-4 text-[var(--muted-text)]">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-2 py-1 text-xs text-[var(--color-peach-paper-accent)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <a
                  href={postHref(post.slug)}
                  class="inline-flex items-center gap-1 font-semibold text-[var(--color-peach-paper-accent)] hover:underline"
                >
                  {t(lang, "blog.readMore")}
                  <span>→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
