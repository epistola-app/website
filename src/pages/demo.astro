---
import Layout from "../components/layout.astro";
import Button from "../components/ui/button.astro";
import Card from "../components/ui/card.astro";
import Title from "../components/ui/title.astro";
import { URLS } from "../lib/URL-helpers";
import { ArrowRight, KeyRound, LayoutTemplate, Workflow, AlertTriangle } from "@lucide/astro";
---

<Layout>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">Live demo</p>
      <Title level={1} class="mt-6">Try Epistola</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        Explore Epistola through two live demo environments. One account gives you access to both.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Login instructions -->
      <Card variant="brand" radius="3xl" shadow="md" padding="lg" class="mx-auto max-w-3xl mb-12">
        <div class="flex items-start gap-4">
          <KeyRound class="w-6 h-6 mt-0.5 shrink-0 text-[var(--color-peach-paper-accent)]" />
          <div>
            <p class="font-semibold text-[var(--color-peach-paper-heading)]">Getting started</p>
            <p class="mt-1 text-[var(--color-peach-paper-copy)]">
              Sign in through <strong>SSO</strong> to create your account — any email address is accepted.
              A single registration gives you access to both demo applications.
            </p>
          </div>
        </div>
      </Card>

      <!-- Two app cards -->
      <div class="grid gap-8 md:grid-cols-2 max-w-5xl mx-auto">

        <!-- Epistola Suite -->
        <Card variant="default" radius="3xl" shadow="md" padding="lg" class="flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-peach-paper-accent)] text-white">
              <LayoutTemplate class="w-5 h-5" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.14em] font-mono text-[var(--color-peach-paper-chip-text)]">
                Epistola Suite
              </p>
            </div>
          </div>
          <Title level={3} class="text-xl">Template management</Title>
          <p class="mt-3 text-[var(--color-peach-paper-copy)] leading-relaxed flex-1">
            Create, edit, version, and promote document templates. Define JSON Schema data bindings and preview rendered output — the full Epistola authoring experience.
          </p>
          <div class="mt-6">
            <Button href={URLS.DEMO} variant="primary" size="md" external class="group">
              Open Epistola Suite
              <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" />
            </Button>
          </div>
        </Card>

        <!-- Valtimo Plugin -->
        <Card variant="default" radius="3xl" shadow="md" padding="lg" class="flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-peach-paper-accent)] text-white">
              <Workflow class="w-5 h-5" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.14em] font-mono text-[var(--color-peach-paper-chip-text)]">
                Valtimo Plugin
              </p>
            </div>
          </div>
          <Title level={3} class="text-xl">Workflow-based document generation</Title>
          <p class="mt-3 text-[var(--color-peach-paper-copy)] leading-relaxed flex-1">
            Start processes in Valtimo that trigger Epistola document generation as part of a workflow. Configure the Epistola plugin, connect templates, and map data from running cases.
          </p>
          <div class="mt-6">
            <Button href={URLS.VALTIMO_DEMO} variant="secondary" size="md" external class="group">
              Open Valtimo demo
              <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" />
            </Button>
          </div>
        </Card>
      </div>

      <!-- Disclaimer -->
      <div class="mx-auto max-w-3xl mt-12 flex items-start gap-3 px-4 py-3 text-sm text-[var(--color-peach-paper-chip-text)]">
        <AlertTriangle class="w-4 h-4 mt-0.5 shrink-0" />
        <p>
          Both environments always run the latest version. They may occasionally be offline or contain pre-release issues.
        </p>
      </div>

    </div>
  </section>

  <section class="py-24">
    <Card variant="brand" radius="4xl" shadow="lg" padding="none" class="mx-auto max-w-4xl px-6 py-16 text-center">
      <Title level={2}>Ready to plug Epistola into your product?</Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        We'll review your templates, map the Common Ground payloads, and help you expose a render endpoint your
        orchestrator can call.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="/docs" variant="primary" size="md">Explore docs</Button>
        <Button href="/pricing" variant="secondary" size="md">Review plans</Button>
      </div>
    </Card>
  </section>
</Layout>
