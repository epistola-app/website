---
import Layout from "../components/layout.astro";
import Title from "../components/ui/title.astro";
import { EMAILS } from "../lib/URL-helpers";
---

<Layout
  title="Epistola · Security"
  description="Security posture for the Epistola project, demo, and managed offering."
>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4">
      <p class="eyebrow">Security</p>
      <Title level={1} class="mt-4"> Security practices </Title>
      <div class="mt-10 space-y-10 text-[var(--color-peach-paper-copy)]">
        <section>
          <Title level={2}>Code transparency</Title>
          <p class="mt-3">
            Epistola is open source. All changes are reviewed via pull requests and undergo automated linting, tests,
            and dependency scanning before release.
          </p>
        </section>
        <section>
          <Title level={2}>Self-hosting</Title>
          <p class="mt-3">
            When you run Epistola yourself, you control the infrastructure, networking, and access policies. We
            recommend isolating render nodes, enabling TLS everywhere, and monitoring outputs for unauthorized changes.
          </p>
        </section>
        <section>
          <Title level={2}>Managed service</Title>
          <p class="mt-3">
            Managed environments are deployed in dedicated namespaces with network policies, encrypted storage, and 24/7
            monitoring. We support EU-region hosting on request.
          </p>
        </section>
        <section>
          <Title level={2}>Responsible disclosure</Title>
          <p class="mt-3">
            Report vulnerabilities privately to <a
              class="underline hover:text-[var(--color-peach-paper-accent)]"
              href={EMAILS.SECURITY}>security@epistola.app</a
            >. We’ll acknowledge receipt within two business days and coordinate remediation steps.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
