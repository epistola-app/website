---
import { getCollection } from "astro:content";
import Layout from "../../../components/layout.astro";
import Title from "../../../components/ui/title.astro";
import { prepareURL, OG_TYPES } from "../../../lib/URL-helpers";
import { useTranslations } from "../../../i18n";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const nlPosts = posts.filter((post) => post.data.locale === "nl");
  return nlPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const { t, locale } = useTranslations(Astro);
const postLocale = post.data.locale || "en";

const allPosts = await getCollection("blog");
const postsInSameLocale = allPosts.filter((p) => (p.data.locale || "en") === postLocale);
const sortedPosts = postsInSameLocale.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const relatedPosts = sortedPosts.filter((p) => p.slug !== post.slug).slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString(postLocale === "nl" ? "nl-NL" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const blogPostTranslations = {
  en: {
    updated: "Updated",
    by: "By",
    backToBlog: "Back to Blog",
    relatedPosts: "Related Posts",
    tableOfContents: "Table of Contents",
  },
  nl: {
    updated: "Bijgewerkt",
    by: "Door",
    backToBlog: "Terug naar Blog",
    relatedPosts: "Gerelateerde Posts",
    tableOfContents: "Inhoudsopgave",
  },
};

const content = blogPostTranslations[postLocale];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
  og={{
    type: OG_TYPES.ARTICLE,
    url: Astro.url.href,
    article: {
      author: post.data.author,
      publishedTime: post.data.date,
      modifiedTime: post.data.updatedDate,
      section: "Blog",
      tags: post.data.tags,
    },
  }}
>
  <article class="pt-32 pb-20">
    {
      post.data.cover && (
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 mb-8">
          <div class="max-w-5xl mx-auto">
            <div class="rounded-2xl overflow-hidden shadow-2xl">
              <img src={post.data.cover} alt={post.data.title} class="w-full h-[400px] md:h-[500px] object-cover" />
            </div>
          </div>
        </div>
      )
    }

    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <header class="mb-8">
          <div class="mb-4 flex flex-wrap items-center gap-4 text-sm text-[var(--muted-text)]">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            {
              post.data.updatedDate && (
                <>
                  <span>•</span>
                  <span>{content.updated} {formatDate(post.data.updatedDate)}</span>
                </>
              )
            }
            <span>•</span>
            <span>{content.by} {post.data.author}</span>
          </div>
          <Title level={1} class="mb-6 font-black leading-tight">
            {post.data.title}
          </Title>
          <p class="mb-6 text-xl leading-relaxed text-[var(--muted-text)] md:text-2xl">
            {post.data.description}
          </p>
          {
            post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-3 py-1 text-sm font-medium text-[var(--color-peach-paper-accent)]">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
        </header>

        <div class="grid lg:grid-cols-5 gap-4">
          <div class="lg:col-span-4">
            <div class="prose prose-lg dark:prose-invert max-w-none">
              <Content />
            </div>

            <div class="mt-16 border-t border-[var(--color-peach-paper-border)] pt-16">
              <a
                href={prepareURL("/blog")}
                class="inline-flex items-center gap-2 font-semibold text-[var(--color-peach-paper-accent)] hover:underline"
              >
                <span>←</span>
                {content.backToBlog}
              </a>
            </div>

            {
              relatedPosts.length > 0 && (
                <div class="mt-16 border-t border-[var(--color-peach-paper-border)] pt-16">
                  <Title level={2} class="mb-8 font-bold">
                    {content.relatedPosts}
                  </Title>
                  <div class="grid md:grid-cols-3 gap-6">
                    {relatedPosts.map((relatedPost) => (
                      <a href={prepareURL("/blog/" + relatedPost.slug)} class="group">
                        <article class="h-full overflow-hidden rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] shadow-lg transition-all hover:shadow-xl">
                          {relatedPost.data.cover && (
                            <img
                              src={relatedPost.data.cover}
                              alt={relatedPost.data.title}
                              class="h-40 w-full object-cover group-hover:scale-105 transition-transform duration-300"
                            />
                          )}
                          <div class="p-5">
                            <div class="mb-2 text-xs text-[var(--color-peach-paper-chip-text)]">
                              {formatDate(relatedPost.data.date)}
                            </div>
                            <Title
                              level={3}
                              class="mb-2 line-clamp-2 text-lg font-bold transition-colors group-hover:text-[var(--color-peach-paper-accent)]"
                            >
                              {relatedPost.data.title}
                            </Title>
                            <p class="line-clamp-2 text-sm text-[var(--muted-text)]">{relatedPost.data.description}</p>
                          </div>
                        </article>
                      </a>
                    ))}
                  </div>
                </div>
              )
            }
          </div>

          <aside class="lg:col-span-1">
            <div class="sticky top-24">
              {
                headings.length > 0 && (
                  <div class="rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] p-4 shadow-lg backdrop-blur-sm">
                    <Title level={3} class="mb-4 text-base font-bold">
                      {content.tableOfContents}
                    </Title>
                    <nav class="text-xs">
                      <ul class="space-y-0">
                        {headings.map((heading) => (
                          <li class={`toc-item toc-h${heading.depth}`}>
                            <a
                              href={`#${heading.slug}`}
                              class="toc-link block rounded-sm border-l-4 border-transparent py-1 pl-2 text-[var(--color-peach-paper-copy)] transition-colors duration-300 hover:border-[var(--color-peach-paper-border-strong)] hover:bg-[var(--color-peach-paper-surface-soft)] hover:text-[var(--color-peach-paper-accent)]"
                            >
                              {heading.text}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </nav>
                  </div>
                )
              }
            </div>
          </aside>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .toc-h2 {
    padding-left: 0;
  }

  .toc-h3 {
    padding-left: 1rem;
  }

  .toc-h4 {
    padding-left: 2rem;
  }
</style>
