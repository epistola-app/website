---
import Layout from "../components/layout.astro";
import IntegrationsCard from "../components/integrations-card.astro";
import Join from "../components/join.astro";
import Title from "../components/ui/title.astro";
---

<Layout>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">Integrations</p>
      <Title level={1} class="mt-6">
        Plug Epistola into Common Ground platforms in days.
      </Title>
      <p class="mt-4 text-lg text-[var(--muted-text)]">
        Use our adapters for GZAC, Valtimo, and ZGW APIs or integrate any
        product over HTTPS.
      </p>
    </div>
  </section>
  <IntegrationsCard />
  <section class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <Title level={2} class="mb-8 text-center"> Integration process </Title>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)]"
            >
              <div
                class="text-2xl font-black text-[var(--color-peach-paper-accent)]"
              >
                01
              </div>
            </div>
            <Title level={3} class="mb-2"> Map your data </Title>
            <p class="text-[var(--muted-text)]">
              Align your zaak, besluit, or custom payloads with template
              variables.
            </p>
          </div>
          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)]"
            >
              <div
                class="text-2xl font-black text-[var(--color-peach-paper-accent)]"
              >
                02
              </div>
            </div>
            <Title level={3} class="mb-2"> Link orchestrator </Title>
            <p class="text-[var(--muted-text)]">
              Call Epistola over HTTPS or message queue, send JSON, and await
              the PDF response.
            </p>
          </div>
          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)]"
            >
              <div
                class="text-2xl font-black text-[var(--color-peach-paper-accent)]"
              >
                03
              </div>
            </div>
            <Title level={3} class="mb-2"> Deliver documents </Title>
            <p class="text-[var(--muted-text)]">
              Push finished files into your DMS, send to citizens, or attach
              back to the case system.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Join />
</Layout>
