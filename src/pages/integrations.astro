---
import Layout from "../components/layout.astro";
import IntegrationsCards from "../components/integrations.astro";
import Join from "../components/join.astro";
---

<Layout>
  <section
    class="pt-32 pb-20 bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1
          class="text-5xl md:text-6xl font-bold mb-6 text-gray-900 dark:text-white"
        >
          Integrate with
          <span class="block mt-2 text-accent-teal"> Your Favorite Tools </span>
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300">
          Connect seamlessly with the services you already use and love.
        </p>
      </div>
    </div>
  </section>
  <IntegrationsCards />
  <section class="py-20 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2
          class="text-3xl md:text-4xl font-bold mb-8 text-center text-gray-900 dark:text-white"
        >
          Easy Integration Process
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div
              class="w-16 h-16 bg-accent-teal/10 dark:bg-accent-teal/20 rounded-full flex items-center justify-center mx-auto mb-4"
            >
              <div class="text-2xl font-black text-accent-teal">01</div>
            </div>
            <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white">
              Choose Integration
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Select from our list of supported integrations
            </p>
          </div>
          <div class="text-center">
            <div
              class="w-16 h-16 bg-accent-teal/10 dark:bg-accent-teal/20 rounded-full flex items-center justify-center mx-auto mb-4"
            >
              <div class="text-2xl font-black text-accent-teal">02</div>
            </div>
            <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white">
              Connect Account
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Authenticate with your service account
            </p>
          </div>
          <div class="text-center">
            <div
              class="w-16 h-16 bg-accent-teal/10 dark:bg-accent-teal/20 rounded-full flex items-center justify-center mx-auto mb-4"
            >
              <div class="text-2xl font-black text-accent-teal">03</div>
            </div>
            <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white">
              Start Using
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Begin using your integrated services
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Join />
</Layout>
