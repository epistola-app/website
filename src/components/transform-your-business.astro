---
import Button from "./ui/button.astro";
import Section from "./ui/section.astro";
import SuiteDemoButton from "./buttons/suite-demo-button.astro";
import { URLS } from "../lib/URL-helpers";
import { useTranslations } from "../i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

const { t, locale } = useTranslations(Astro);
const transform = t("transformYourBusiness");
---

<Section
  monoTitle={transform.monoTitle}
  title={transform.title}
  description={transform.description}
  contentClass="flex flex-wrap justify-center gap-4"
>
  <SuiteDemoButton />
  <Button href={URLS.VALTIMO_DEMO} variant="secondary" size="md" external>{transform.valtimoDemo}</Button>
  <Button href={getRelativeLocaleUrl(locale, "/integrations")} variant="link" size="md">{transform.viewIntegrations}</Button>
</Section>
