---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const cards = filterDataByLocale(items, lang, "integration-card");
---

<Section
  monoTitle={t(lang, "integrations.monoTitle")}
  title={t(lang, "integrations.title")}
  description={t(lang, "integrations.description")}
  contentClass="space-y-10"
>
  <div class="grid gap-6 md:grid-cols-3">
    {
      cards.map((card) => (
        <Card variant="subtle">
          <p class="text-sm font-semibold">{card.data.title}</p>
          <p class="mt-2 text-sm text-[var(--muted-text)]">
            {card.data.description}
          </p>
        </Card>
      ))
    }
  </div>
  <Card variant="outline" class="text-sm text-[var(--muted-text)]">
    <p class="font-semibold text-[var(--color-peach-paper-heading)]">{t(lang, "integrations.roadmap.title")}</p>
    <p class="mt-2">
      {t(lang, "integrations.roadmap.description")}
    </p>
  </Card>
</Section>
