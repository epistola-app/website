---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);
const integrations = t("integrationsOverview");
---

<Section
  monoTitle={integrations.monoTitle}
  title={integrations.title}
  description={integrations.description}
  contentClass="space-y-10"
>
  <div class="grid gap-6 md:grid-cols-3">
    {integrations.cards.map((card) => (
      <Card variant="subtle">
        <p class="text-sm font-semibold">{card.title}</p>
        <p class="mt-2 text-sm text-[var(--muted-text)]">{card.body}</p>
      </Card>
    ))}
  </div>
  <Card variant="outline" class="text-sm text-[var(--muted-text)]">
    <p class="font-semibold text-[var(--color-peach-paper-heading)]">{integrations.roadmapTitle}</p>
    <p class="mt-2">{integrations.roadmapText}</p>
  </Card>
</Section>
