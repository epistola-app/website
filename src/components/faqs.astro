---
import Accordion from "./Accordion.astro";


const faqItems = [
  {
    question: "What is included in the template?",
    answer: "The template includes all pages (Home, Features, Pricing, Integrations, Blog, Docs, Login/Register), multiple hero variations, dark mode, SEO optimization, and animations."
  },
  {
    question: "Can I customize the design?",
    answer: "Yes! The template is built with Tailwind CSS and is fully customizable. All components are well-organized and easy to modify."
  },
  {
    question: "Do I need to know Astro to use this?",
    answer: "Basic knowledge of HTML/CSS and JavaScript is helpful, but the template is well-documented and easy to understand even for beginners."
  },
  {
    question: "Is there support included?",
    answer: "Yes, we provide email support for all customers. Professional and Enterprise plans include priority support."
  }
];
---

<section class="py-20 bg-gray-50 dark:bg-gray-800">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight tracking-tight"
      >
        <span
          class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 dark:from-white dark:via-gray-100 dark:to-white bg-clip-text text-transparent"
          >Frequently asked</span
        ><br /><span class="text-accent-teal">questions</span>
      </h2>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 font-light"
      >
        Everything you need to know about the template
      </p>
    </div>
    <div class="max-w-3xl mx-auto">
      <Accordion items={faqItems} />
    </div>
  </div>
</section>
