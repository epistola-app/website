---
import Accordion from "./accordion.astro";
import Title from "./ui/title.astro";

const faqItems = [
  {
    question: "How fast can we launch?",
    answer:
      "Most teams move from the demo environment to production in about 6 weeks. We help migrate a core set of templates and connect your orchestrator so you stay focused on your product.",
  },
  {
    question: "Can Epistola connect to our legacy systems?",
    answer:
      "Yes. We provide adapters for major CRMs, loan origination, core banking, and signature vendors. Our platform exposes REST/GraphQL APIs and event hooks for everything else.",
  },
  {
    question: "How is compliance handled?",
    answer:
      "Policy teams codify guardrails once. Every template, clause, and channel inherits those controls with auditable checkpoints and approval workflows.",
  },
  {
    question: "What support is included?",
    answer:
      "Scale and Enterprise plans include dedicated delivery managers, 24/7 support, and quarterly governance reviews.",
  },
];
---

<section class="py-20 [background-image:var(--gradient-peach-paper-soft)]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <Title
        level={2}
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight tracking-tight"
      >
        <span class="text-[var(--color-peach-paper-heading)]"
          >Frequently asked</span
        ><br /><span class="text-[var(--color-peach-paper-accent)]"
          >questions</span
        >
      </Title>
      <p class="text-xl md:text-2xl text-[var(--muted-text)] font-light">
        Everything you need to know about the template
      </p>
    </div>
    <div class="max-w-3xl mx-auto">
      <Accordion items={faqItems} />
    </div>
  </div>
</section>
