---
import Section from "./ui/section.astro";

const faqItems = [
  {
    question: "How fast can we launch?",
    answer:
      "Timelines mainly depend on how quickly your infrastructure lands. Epistola ships everything you need on day one, so once access is provisioned we can start templating immediately. Our optional AI-assisted authoring trims the time it takes to shape bespoke templates.",
    isActive: true,
  },
  {
    question: "Can Epistola connect to our legacy systems?",
    answer:
      "We provide first-class integration with Common Ground and expose a REST API that any other system can call. Need something custom? We scope and deliver dedicated adapters on request.",
    isActive: false,
  },
  {
    question: "How is compliance handled?",
    answer:
      "Every implementation is tracked against a client-specific compliance model inside a bespoke register. All Epistola operations are logged so auditors can retrace every change and delivery.",
    isActive: false,
  },
  {
    question: "What support is included?",
    answer:
      "Scale and Enterprise plans include dedicated delivery managers, 24/7 support, and quarterly governance reviews.",
    isActive: false,
  },
];
---

<Section
  monoTitle="/ Frequently asked questions"
  title="Everything you need to know"
  description="Answers about launch timelines, integrations, compliance, and support."
  contentClass="grid gap-6 lg:grid-cols-2 h-full"
  data-faq-switcher
>
  <div class="flex flex-col gap-4">
    {
      faqItems.map((item, index) => (
        <button
          type="button"
          data-faq-button
          data-faq-index={index}
          data-active={item.isActive ? "true" : "false"}
          class:list={{
            "flex items-start gap-4 border border-(--color-peach-paper-border) px-5 py-4 text-left transition-[width,opacity,background-color] duration-200": true,
            "w-full": item.isActive,
            "w-[95%]": !item.isActive,
            "opacity-70": !item.isActive,
            "bg-[var(--color-peach-paper-chip-bg)]": item.isActive,
          }}
          aria-pressed={item.isActive ? "true" : "false"}
        >
          <span class="text-xs font-semibold uppercase tracking-[0.18em] text-(--color-peach-paper-chip-text)">
            Q{String(index + 1).padStart(2, "0")}
          </span>
          <span class="text-base font-semibold text-(--color-peach-paper-heading)">{item.question}</span>
        </button>
      ))
    }
  </div>
  <div class="relative">
    {
      faqItems.map((item, index) => (
        <article
          class:list={{
            "border border-(--color-peach-paper-border) bg-(--color-peach-paper-chip-bg) p-6 h-full": true,
            hidden: !item.isActive,
          }}
          data-faq-panel
          data-faq-index={index}
          aria-hidden={item.isActive ? "false" : "true"}
        >
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-(--color-peach-paper-chip-text)">
            Answer
          </p>
          <p class="mt-3 text-lg font-semibold text-(--color-peach-paper-heading)" data-faq-title>
            {item.question}
          </p>
          <p class="mt-4 text-base leading-relaxed text-(--color-peach-paper-copy)" data-faq-copy>
            {item.answer}
          </p>
        </article>
      ))
    }
  </div>
</Section>

<script is:inline>
  const faqSections = document.querySelectorAll("[data-faq-switcher]");

  const initFaqSection = (section) => {
    const buttons = Array.from(section.querySelectorAll("[data-faq-button]"));
    const panels = Array.from(section.querySelectorAll("[data-faq-panel]"));

    if (!buttons.length || !panels.length) return;

    const setActive = (activeIndex, shouldAnimate = false) => {
      buttons.forEach((button, index) => {
        const isActive = index === activeIndex;
        button.classList.toggle("bg-[var(--color-peach-paper-chip-bg)]", isActive);
        button.classList.toggle("opacity-70", !isActive);
        button.classList.toggle("w-full", isActive);
        button.classList.toggle("w-[95%]", !isActive);
        button.setAttribute("aria-pressed", String(isActive));
        button.setAttribute("data-active", isActive ? "true" : "false");
      });

      panels.forEach((panel, index) => {
        const isActive = index === activeIndex;
        panel.setAttribute("aria-hidden", String(!isActive));

        if (isActive) {
          panel.classList.remove("hidden");

          if (shouldAnimate) {
            panel.classList.add("opacity-0", "translate-y-1");
            panel.classList.remove("opacity-100", "translate-y-0");

            requestAnimationFrame(() => {
              panel.classList.add("transition-all", "duration-200", "ease-out");
              panel.classList.add("opacity-100", "translate-y-0");
              panel.classList.remove("opacity-0", "translate-y-1");
            });
          } else {
            panel.classList.remove("opacity-0", "translate-y-1");
            panel.classList.add("opacity-100", "translate-y-0");
          }
        } else {
          panel.classList.add("hidden");
          panel.classList.remove("transition-all", "duration-200", "ease-out");
        }
      });
    };

    const defaultIndex = Math.max(
      0,
      buttons.findIndex((button) => button.getAttribute("data-active") === "true"),
    );

    setActive(defaultIndex, false);

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => setActive(index, true));
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      faqSections.forEach(initFaqSection);
    });
  } else {
    faqSections.forEach(initFaqSection);
  }
</script>
