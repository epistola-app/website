---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";

const integratorHighlights = [
  "JSON Schema Draft 2020-12 validation before render",
  "Immutable template versions per environment and tenant",
  "OpenAPI 3.1 endpoints + adaptive batch job webhooks",
];
---

<Section
  monoTitle="/ Built for integrators"
  title="Leave orchestration where it already lives."
  description="Epistola exposes a guarded render surface that fits into Common Ground and bespoke platforms without forcing workflow rewrites."
  contentClass="grid grid-cols-1 gap-12 lg:grid-cols-6"
>
  <div class="lg:col-start-2 lg:col-span-2">
    <ul class="space-y-4">
      {
        integratorHighlights.map((item) => (
          <li class="flex items-start">
            <svg class="mr-3 h-6 w-6 text-[var(--color-peach-paper-accent)]" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"
              />
            </svg>
            <span class="text-[var(--color-peach-paper-copy)]">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
  <Card variant="default" padding="lg" shadow="none" class="text-center lg:col-span-2">
    <p class="text-5xl font-semibold text-[var(--color-peach-paper-accent)]">50-200 ms</p>
    <p class="mt-2 text-sm uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">render window (iText)</p>
  </Card>
</Section>
