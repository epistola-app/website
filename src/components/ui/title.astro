---
interface Props {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  class?: string;
}

const { level = 2, class: className = "", ...restProps } = Astro.props as Props;

const levelClasses = {
  1: "text-4xl md:text-5xl lg:text-6xl",
  2: "text-3xl md:text-4xl",
  3: "text-xl md:text-2xl",
  4: "text-lg md:text-xl",
  5: "text-base md:text-lg",
  6: "text-sm md:text-base",
} as const;

const Tag = `h${level}`;
---

<Tag class={`font-semibold text-balance text-[var(--color-peach-paper-heading)] ${levelClasses[level]} ${className}`} {...restProps}>
  <slot />
</Tag>
