---
import Title from "./title.astro";
import { type Locale, DEFAULT_LOCALE } from "../../i18n";

interface Props {
  title: string;
  description: string;
  backHref: string;
  backLabel: string;
  lang?: Locale;
}

const { title, description, backHref, backLabel, lang = DEFAULT_LOCALE } = Astro.props;
---

<div class="pt-32 pb-20">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-7xl">
      <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-10">
        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-32">
            <slot name="nav" />
          </div>
        </aside>

        <!-- Content -->
        <div class="mx-auto max-w-3xl">
          <header class="mb-8">
            <a
              href={backHref}
              class="mb-4 inline-block text-sm font-semibold text-[var(--color-peach-paper-accent)] hover:underline"
            >
              {backLabel}
            </a>
            <Title level={1} class="mb-4 font-black leading-tight">
              {title}
            </Title>
            <p class="text-lg text-[var(--muted-text)]">{description}</p>
          </header>

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <slot />
          </div>

          <slot name="footer" />
        </div>
      </div>
    </div>
  </div>
</div>
