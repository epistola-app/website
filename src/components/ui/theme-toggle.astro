---
import { useTranslations } from "../../i18n";
import { cn } from "../../lib/cn";

interface Props {
  mobile?: boolean;
  class?: string;
  id?: string;
}

const { mobile = false, class: className = "", id } = Astro.props as Props;
const { t } = useTranslations(Astro);
const common = t("common");
---

{
  mobile ? (
    <button
      id={id}
      type="button"
      data-theme-toggle
      aria-label={common.toggleTheme}
      aria-pressed="false"
      data-theme-light-label={common.light}
      data-theme-dark-label={common.dark}
      data-theme-switch-to-light={common.switchToLightTheme}
      data-theme-switch-to-dark={common.switchToDarkTheme}
      class={cn("inline-flex items-center gap-3 text-sm font-semibold text-(--color-peach-paper-copy)", className)}
    >
      <span>{common.theme}</span>
      <span data-theme-toggle-state class="text-[10px] uppercase tracking-[0.14em] text-(--color-peach-paper-copy)">
        {common.light}
      </span>
      <span class="relative h-6 w-12 rounded-none border border-(--color-peach-paper-border) p-0.5">
        <span
          data-theme-toggle-pill
          class="block h-5 w-5 rounded-none bg-(--color-peach-paper-accent) transition-transform"
        />
      </span>
    </button>
  ) : (
    <button
      id={id}
      type="button"
      data-theme-toggle
      aria-label={common.switchToDarkTheme}
      aria-pressed="false"
      data-theme-light-label={common.light}
      data-theme-dark-label={common.dark}
      data-theme-switch-to-light={common.switchToLightTheme}
      data-theme-switch-to-dark={common.switchToDarkTheme}
      class={cn(
        "flex h-10 w-10 items-center justify-center rounded-none border border-(--color-peach-paper-border) bg-(--color-peach-paper-chip-bg) text-(--color-peach-paper-heading) transition hover:border-(--color-peach-paper-border-strong) hover:text-(--color-peach-paper-accent)",
        className,
      )}
    >
      <span class="sr-only" data-theme-toggle-label>
        {common.switchToDarkTheme}
      </span>
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path
          data-theme-toggle-icon-path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 3.75A8.25 8.25 0 1 0 20.25 12 6.75 6.75 0 0 1 12 3.75z"
        />
      </svg>
    </button>
  )
}
