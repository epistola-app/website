---
import HeroCta from "./ui/hero-cta.astro";
---

<section
  class="relative pt-32 pb-20 overflow-hidden min-h-screen flex items-center bg-accent-light/10 dark:bg-accent-dark"
>
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=1920&h=1080&fit=crop&q=80"
      alt=""
      class="w-full h-full object-cover opacity-100 dark:opacity-100"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-white/60 via-white/40 to-white/60 dark:from-accent-dark/60 dark:via-accent-dark/40 dark:to-accent-dark/60 backdrop-blur-3xl"
    >
    </div>
  </div>

  <div
    class="absolute inset-0 z-0 opacity-100 dark:opacity-100"
    style="
      background-image: repeating-linear-gradient(0deg, rgba(5, 94, 104, 0.1) 0 1px, transparent 1px 30px),
                        repeating-linear-gradient(90deg, rgba(5, 94, 104, 0.1) 0 1px, transparent 1px 30px);
      background-size: 30px 30px;
    "
  >
  </div>

  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div
      class="absolute top-20 right-10 w-72 h-72 bg-accent-teal/15 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-20 left-10 w-64 h-64 bg-accent-green/15 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-accent-light/20 rounded-full blur-2xl"
    >
    </div>
    <div
      class="absolute top-1/4 right-1/4 w-32 h-32 bg-accent-teal/10 rounded-full blur-xl"
    >
    </div>
    <div
      class="absolute bottom-1/3 right-1/3 w-40 h-40 bg-accent-green/10 rounded-full blur-xl"
    >
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-4xl mx-auto">
      <div>
        <span
          class="inline-flex items-center px-4 py-2 mb-6 text-sm font-medium text-accent-teal bg-accent-light/50 dark:bg-accent-dark/50 backdrop-blur-sm border border-accent-teal/20 rounded-full"
        >
          Launch your SaaS in days, not months
        </span>
      </div>

      <h1
        class="text-6xl md:text-7xl lg:text-8xl font-bold mb-8 leading-[1.1] tracking-tight"
      >
        <span class="block text-accent-dark dark:text-accent-light"
          >Build Your SaaS</span
        >
        <span class="block mt-2 text-accent-teal">Landing Page</span>
        <span class="block mt-2 text-accent-dark dark:text-accent-light"
          >in Minutes</span
        >
      </h1>

      <p
        class="text-xl md:text-2xl text-accent-dark/80 dark:text-accent-light/80 mb-12 max-w-3xl mx-auto font-normal leading-relaxed"
      >
        Premium Astro template with everything you need to launch your SaaS
        product. Beautiful design, fully responsive, and optimized for
        conversions.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <HeroCta url="/register" text="Get Started Free" />
        <HeroCta url="/features" text="View Features" />
      </div>

      <div class="mt-16 grid grid-cols-3 gap-6 max-w-2xl mx-auto">
        <div
          class="bg-white/80 dark:bg-accent-dark/50 backdrop-blur-sm border border-accent-dark/10 dark:border-accent-light/10 rounded-lg p-6 hover:shadow-lg transition-all"
        >
          <div class="text-3xl font-bold text-accent-teal">10K+</div>
          <div
            class="text-sm text-accent-dark/70 dark:text-accent-light/70 mt-1"
          >
            Active Users
          </div>
        </div>
        <div
          class="bg-white/80 dark:bg-accent-dark/50 backdrop-blur-sm border border-accent-dark/10 dark:border-accent-light/10 rounded-lg p-6 hover:shadow-lg transition-all"
        >
          <div class="text-3xl font-bold text-accent-teal">99.9%</div>
          <div
            class="text-sm text-accent-dark/70 dark:text-accent-light/70 mt-1"
          >
            Uptime
          </div>
        </div>
        <div
          class="bg-white/80 dark:bg-accent-dark/50 backdrop-blur-sm border border-accent-dark/10 dark:border-accent-light/10 rounded-lg p-6 hover:shadow-lg transition-all"
        >
          <div class="text-3xl font-bold text-accent-teal">24/7</div>
          <div
            class="text-sm text-accent-dark/70 dark:text-accent-light/70 mt-1"
          >
            Support
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
