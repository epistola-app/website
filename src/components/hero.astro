---
import Button from "./ui/button.astro";
import Title from "./ui/title.astro";
import { ArrowRight } from "@lucide/astro";
---

<section
  class="relative flex min-h-auto lg:min-h-[calc(100dvh-80px)] flex-col justify-center overflow-hidden px-4 py-12"
>
  <div
    class="absolute inset-0 -z-10 opacity-70 [background-image:var(--gradient-peach-paper)]"
  >
  </div>
  <div
    class="grid mx-auto w-full max-w-6xl gap-12 lg:grid-cols-2 lg:gap-24"
  >
    <div class="flex items-center">
      <Title
        level={1}
        class="text-4xl lg:text-[3.5rem] leading-tight lg:leading-snug"
      >
        <span class="hidden lg:block"
          >The open-source document platform<br />for enterprise.</span
        >
        <span class="lg:hidden"
          >The open-source document platform for enterprise.</span
        >
      </Title>
    </div>
    <div
      class="flex flex-col justify-center text-center lg:items-start lg:text-left gap-8"
    >
      <p class="text-base lg:text-lg text-[var(--muted-text)] leading-normal">
        Build templates visually, enforce data contracts, and generate compliant
        PDFs at scale. Built-in governance, version control, and
        multi-environment promotions.
      </p>
      <div class="flex flex-row w-full justify-center lg:justify-start gap-4">
        <Button
          href="https://demo.epistola.app"
          variant="primary"
          size="lg"
          external
          class="uppercase font-[family-name:var(--font-mono)] text-sm tracking-wider group"
        >
          Open demo
          <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" />
        </Button>
        <Button
          href="https://docs.epistola.app"
          variant="secondary"
          size="lg"
          external
          class="uppercase font-[family-name:var(--font-mono)] text-sm tracking-wider"
        >
          Explore docs
        </Button>
      </div>
    </div>
  </div>
</section>
