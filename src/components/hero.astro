---
import Button from "./ui/button.astro";
import Card from "./ui/card.astro";
import Title from "./ui/title.astro";
---

<section
  class="relative overflow-hidden pt-40 pb-24 [background-image:var(--gradient-peach-paper-soft)]"
>
  <div
    class="absolute inset-0 -z-10 opacity-70 [background-image:var(--gradient-peach-paper)]"
  >
  </div>
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 gap-16 px-4 lg:grid-cols-[1.1fr_0.9fr]"
  >
    <div>
      <p class="eyebrow mb-6">Document generation platform</p>
      <Title level={1} class="lg:text-[3.5rem]">
        Visual authoring, typed data contracts, and a render API in one stack.
      </Title>
      <p class="mt-6 text-lg text-[var(--muted-text)]">
        Epistola Suite combines a Lit/ProseMirror editor, JSON Schema contracts,
        and an iText-powered renderer. Multi-tenant governance, immutable
        template versions, and environment promotions are built in so developers
        and DocOps teams can deliver compliant PDFs without inventing new
        tooling.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <Button
          href="https://demo.epistola.app"
          variant="primary"
          size="lg"
          external>Open demo</Button
        >
        <Button
          href="https://docs.epistola.app"
          variant="secondary"
          size="lg"
          external
        >
          Explore docs
        </Button>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        <Card variant="subtle" padding="sm">
          <p class="text-sm font-medium text-[var(--color-peach-paper-copy)]">
            Template versions
          </p>
          <p
            class="mt-2 text-3xl font-semibold text-[var(--color-peach-paper-accent)]"
          >
            200+
          </p>
          <p class="text-sm text-[var(--color-peach-paper-copy)]">
            per variant with draft/publish states
          </p>
        </Card>
        <Card variant="subtle" padding="sm">
          <p class="text-sm font-medium text-[var(--color-peach-paper-copy)]">
            Render latency
          </p>
          <p class="mt-2 text-3xl font-semibold">50–200 ms</p>
          <p class="text-sm text-[var(--color-peach-paper-copy)]">
            direct iText pipeline
          </p>
        </Card>
        <Card variant="subtle" padding="sm">
          <p class="text-sm font-medium text-[var(--color-peach-paper-copy)]">
            Tenants onboarded
          </p>
          <p class="mt-2 text-3xl font-semibold">Multi-tenant</p>
          <p class="text-sm text-[var(--color-peach-paper-copy)]">
            role &amp; environment isolation
          </p>
        </Card>
      </div>
    </div>
    <div class="relative">
      <Card
        variant="default"
        radius="3xl"
        padding="lg"
        shadow="md"
        class="relative overflow-hidden"
      >
        <div
          class="absolute -left-12 top-6 h-24 w-24 rounded-full bg-[var(--color-peach-paper-border)] blur-3xl"
        >
        </div>
        <div
          class="absolute -right-16 bottom-0 h-32 w-32 rounded-full bg-[var(--color-peach-paper-border-strong)] blur-3xl"
        >
        </div>
        <div class="relative space-y-6">
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-peach-paper-accent)]"
            >
              Template variant
            </p>
            <Title level={2} class="mt-2 text-2xl"
              >Correspondentie · nl_corporate</Title
            >
          </div>
          <div
            class="space-y-4 rounded-2xl border border-dashed border-[var(--color-peach-paper-border-soft)] bg-[var(--color-peach-paper-surface-soft)] p-4 text-sm"
          >
            <div class="flex items-center justify-between">
              <span class="font-medium">Revision</span>
              <span
                class="rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-3 py-1 text-xs font-semibold text-[var(--color-peach-paper-accent)]"
                >v12 · Published</span
              >
            </div>
            <div class="grid gap-3 text-sm">
              <div
                class="rounded-xl bg-[var(--color-peach-paper-chip-bg)] p-3 shadow-sm"
              >
                <p
                  class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]"
                >
                  Data contract
                </p>
                <p class="mt-1 font-semibold">JSON Schema · Draft 2020-12</p>
              </div>
              <div
                class="rounded-xl bg-[var(--color-peach-paper-chip-bg)] p-3 shadow-sm"
              >
                <p
                  class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]"
                >
                  Expressions
                </p>
                <p class="mt-1 font-semibold">JSONata · GraalJS · Path</p>
              </div>
              <div
                class="rounded-xl bg-[var(--color-peach-paper-chip-bg)] p-3 shadow-sm"
              >
                <p
                  class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]"
                >
                  Guardrails
                </p>
                <p class="mt-1 font-semibold">Tenant scoped · audit logged</p>
              </div>
            </div>
          </div>
          <div
            class="rounded-2xl border border-[var(--color-peach-paper-border-strong)] bg-[var(--color-peach-paper-chip-bg)] p-5 text-sm shadow-inner"
          >
            <p class="font-medium text-[var(--color-peach-paper-heading)]">
              Job timeline
            </p>
            <ul class="mt-3 space-y-2">
              <li class="flex items-center gap-2">
                <span class="h-2 w-2 rounded-full bg-[var(--color-success-500)]"
                ></span>
                PENDING → PROCESSING in 12 ms (batch size auto tuned)
              </li>
              <li class="flex items-center gap-2">
                <span class="h-2 w-2 rounded-full bg-[var(--color-success-500)]"
                ></span>
                RENDER COMPLETE · checksum stored
              </li>
              <li class="flex items-center gap-2">
                <span class="h-2 w-2 rounded-full bg-[var(--color-warning-500)]"
                ></span>
                Delivery hook retried (S3 503) · resolved
              </li>
            </ul>
          </div>
        </div>
      </Card>
    </div>
  </div>
</section>
