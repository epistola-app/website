---
import HeroStats from "./hero-stats.astro";
import Button from "./ui/button.astro";
import Title from "./ui/title.astro";
import SuiteDemoButton from "./buttons/suite-demo-button.astro";
import { ArrowRight } from "@lucide/astro";
import { URLS } from "../lib/URL-helpers";
import { t, localePath, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
---

<section
  class="relative flex min-h-auto lg:min-h-[calc(100dvh-80px)] flex-col justify-around overflow-hidden px-4 py-12"
>
  <div class="absolute inset-0 -z-10 opacity-70"></div>
  <div class="grid container mx-auto w-full lg:grid-cols-7">
    <div class="flex items-center col-span-4">
      <Title
        level={1}
        class="text-4xl lg:text-[3.5rem] leading-tight lg:leading-snug text-center lg:text-left text-balance"
      >
        <span class="hidden lg:block">
          {t(lang, "hero.title.line1")}<br />{t(lang, "hero.title.line2")}
        </span>
        <span class="lg:hidden"> {t(lang, "hero.title.line1")} {t(lang, "hero.title.line2")} </span>
      </Title>
    </div>
    <div class="flex flex-col col-span-3 justify-center text-center lg:items-start lg:text-left gap-8">
      <p class="text-base lg:text-lg text-(--muted-text) leading-normal text-balance">
        {t(lang, "hero.description")}
      </p>
      <div class="flex flex-col gap-3 w-full justify-center lg:flex-row lg:gap-4 lg:justify-start">
        <SuiteDemoButton lang={lang} />
        <Button href={localePath(lang, "/learn/tour")} variant="secondary" size="md"> {t(lang, "tour.cta.startTour")} </Button>
        <Button href={localePath(lang, "/learn")} variant="secondary" size="md"> {t(lang, "hero.cta.exploreDocs")} </Button>
      </div>
    </div>
  </div>
  <HeroStats lang={lang} />
  <svg
    xmlns="http://www.w3.org/2000/svg"
    version="1.1"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    viewBox="0 0 1422 800"
    opacity="0.4"
    class="absolute inset-0 -z-1"
  >
    <defs>
      <linearGradient x1="50%" y1="0%" x2="50%" y2="100%" id="oooscillate-grad">
        <stop stop-color="hsl(15, 42%, 51%)" stop-opacity="1" offset="0%"> </stop>
        <stop stop-color="hsl(15, 42%, 51%)" stop-opacity="1" offset="100%"> </stop>
      </linearGradient>
    </defs><g stroke-width="1" stroke="hsl(32, 100%, 51%)" fill="none" stroke-linecap="round">
      <path d="M 0 1000 Q 355.5 180 711 400 Q 1066.5 620 1422 1000" opacity="0.22"> </path><path
        d="M 0 875 Q 355.5 180 711 400 Q 1066.5 620 1422 875"
        opacity="0.44"
      >
      </path><path d="M 0 750 Q 355.5 180 711 400 Q 1066.5 620 1422 750" opacity="0.27"> </path><path
        d="M 0 625 Q 355.5 180 711 400 Q 1066.5 620 1422 625"
        opacity="0.28"
      >
      </path><path d="M 0 500 Q 355.5 180 711 400 Q 1066.5 620 1422 500" opacity="0.32"> </path><path
        d="M 0 375 Q 355.5 180 711 400 Q 1066.5 620 1422 375"
        opacity="0.63"
      >
      </path><path d="M 0 250 Q 355.5 180 711 400 Q 1066.5 620 1422 250" opacity="0.64"> </path>
    </g>
  </svg>
</section>
