---
import Card from "./ui/card.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
---

<section class="py-20">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 md:grid-cols-4">
    {
      [
        { label: t(lang, "stats.0.label"), value: t(lang, "stats.0.value") },
        { label: t(lang, "stats.1.label"), value: t(lang, "stats.1.value") },
        { label: t(lang, "stats.2.label"), value: t(lang, "stats.2.value") },
        { label: t(lang, "stats.3.label"), value: t(lang, "stats.3.value") },
      ].map((item, index) => (
        <Card variant={index % 2 === 0 ? "subtle" : "default"} class="text-center">
          <p class="text-4xl font-semibold text-[var(--color-peach-paper-accent)]">{item.value}</p>
          <p class="mt-2 text-sm font-medium uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
            {item.label}
          </p>
        </Card>
      ))
    }
  </div>
</section>
