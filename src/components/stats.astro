---
import Card from "./ui/card.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);

// These are placeholder stats - in real implementation would come from data
const stats = [
  { label: t("common").statsTemplates || "templates in git", value: "8.2k" },
  { label: t("common").statsRenderJobs || "render jobs / day", value: "140k" },
  { label: t("common").statsCompliance || "pdf/a compliance", value: "100%" },
  { label: t("common").statsDockerPulls || "docker pull / month", value: "4.1k" },
];
---

<section class="py-20">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 md:grid-cols-4">
    {
      stats.map((item, index) => (
        <Card variant={index % 2 === 0 ? "subtle" : "default"} class="text-center">
          <p class="text-4xl font-semibold text-[var(--color-peach-paper-accent)]">{item.value}</p>
          <p class="mt-2 text-sm font-medium uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
            {item.label}
          </p>
        </Card>
      ))
    }
  </div>
</section>
