---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);
const howItWorks = t("howItWorks");
---

<Section
  monoTitle={howItWorks.monoTitle}
  title={howItWorks.title}
  contentClass="mx-auto grid gap-8 md:grid-cols-3"
>
  {
    howItWorks.steps.map((step, index) => (
      <Card variant="subtle" class="relative">
        <span class="text-sm font-semibold text-[var(--color-peach-paper-accent)]">0{index + 1}</span>
        <Title level={3} class="mt-4">
          {step.title}
        </Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{step.body}</p>
      </Card>
    ))
  }
</Section>
