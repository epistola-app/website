---
import { getCollection } from "astro:content";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const steps = filterDataByLocale(items, lang, "how-it-works");

const illustrationPaths = [
  "/illustrations/how-it-works/step1.svg",
  "/illustrations/how-it-works/step2.svg",
  "/illustrations/how-it-works/step3.svg",
  "/illustrations/how-it-works/step4.svg",
  "/illustrations/how-it-works/step5.svg",
  "/illustrations/how-it-works/step6.svg",
];
---

<Section
  monoTitle={t(lang, "howItWorks.monoTitle")}
  title={t(lang, "howItWorks.title")}
  contentClass="mx-auto flex flex-col gap-20 md:gap-32"
>
  {
    steps.map((step, index) => (
      <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
        <div class:list={["order-2 flex flex-col justify-center", index % 2 === 0 ? "md:order-1 md:pr-8 md:items-end md:text-right" : "md:order-2 md:pl-8"]}>
          <div class="flex items-baseline gap-4">
            <span class="text-7xl md:text-8xl font-bold text-[var(--color-peach-paper-accent)] opacity-20 leading-none">
              {String(index + 1).padStart(2, "0")}
            </span>
            <span class="text-sm font-semibold tracking-[0.2em] uppercase text-[var(--color-peach-paper-accent)]">
              Step
            </span>
          </div>
          <Title level={3} class="mt-2 text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-peach-paper-heading)] tracking-tight leading-tight">
            {step.data.title}
          </Title>
          <p class="mt-6 text-lg md:text-xl text-[var(--muted-text)] leading-relaxed max-w-lg">
            {step.data.body}
          </p>
        </div>
        <div class:list={["order-1", index % 2 === 0 ? "md:order-2" : "md:order-1"]}>
          <div class="relative aspect-[16/10] w-full overflow-hidden">
            <img
              src={illustrationPaths[index]}
              alt={`Illustration for step ${index + 1}: ${step.data.title}`}
              class="h-full w-full object-contain p-4"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    ))
  }
</Section>
