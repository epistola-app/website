---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const steps = [
  {
    title: t(lang, "howItWorks.step.0.title"),
    body: t(lang, "howItWorks.step.0.body"),
  },
  {
    title: t(lang, "howItWorks.step.1.title"),
    body: t(lang, "howItWorks.step.1.body"),
  },
  {
    title: t(lang, "howItWorks.step.2.title"),
    body: t(lang, "howItWorks.step.2.body"),
  },
];
---

<Section
  monoTitle={t(lang, "howItWorks.monoTitle")}
  title={t(lang, "howItWorks.title")}
  contentClass="mx-auto grid gap-8 md:grid-cols-3"
>
  {
    steps.map((step, index) => (
      <Card variant="subtle" class="relative">
        <span class="text-sm font-semibold text-[var(--color-peach-paper-accent)]">0{index + 1}</span>
        <Title level={3} class="mt-4">
          {step.title}
        </Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{step.body}</p>
      </Card>
    ))
  }
</Section>
