---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const steps = filterDataByLocale(items, lang, "how-it-works");
---

<Section
  monoTitle={t(lang, "howItWorks.monoTitle")}
  title={t(lang, "howItWorks.title")}
  contentClass="mx-auto grid gap-8 md:grid-cols-3"
>
  {
    steps.map((step, index) => (
      <Card variant="subtle" class="relative">
        <span class="text-sm font-semibold text-[var(--color-peach-paper-accent)]">0{index + 1}</span>
        <Title level={3} class="mt-4">
          {step.data.title}
        </Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{step.data.body}</p>
      </Card>
    ))
  }
</Section>
