---
import Card from "./ui/card.astro";
import Title from "./ui/title.astro";

const steps = [
  {
    title: "Model + author",
    body: "Define JSON Schema contracts, manage variants, and drag blocks in the Lit/ProseMirror editor with live PDF preview.",
  },
  {
    title: "Promote + govern",
    body: "Freeze versions, assign them to staging/production environments, and gate releases behind reviewer approvals per tenant.",
  },
  {
    title: "Render + deliver",
    body: "Call the REST API or batch jobs, let iText render PDFs in milliseconds, then push artifacts via storage adapters or webhooks.",
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-5xl px-4">
    <div class="text-center">
      <p class="eyebrow">How it works</p>
      <Title level={2} class="mt-4">
        A single path from template to PDF.
      </Title>
    </div>
    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        steps.map((step, index) => (
          <Card variant="subtle" class="relative">
            <span class="text-sm font-semibold text-[var(--color-peach-paper-accent)]">
              0{index + 1}
            </span>
            <Title level={3} class="mt-4">
              {step.title}
            </Title>
            <p class="mt-3 text-sm text-[var(--muted-text)]">{step.body}</p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
