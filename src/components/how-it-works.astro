---

---

<section class="py-20 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight tracking-tight"
      >
        <span
          class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 dark:from-white dark:via-gray-100 dark:to-white bg-clip-text text-transparent"
          >How it works</span
        >
      </h2>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 font-light"
      >
        Get started in three simple steps
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <div class="relative text-center z-10">
        <div
          class="hidden md:block absolute top-12 left-full w-full h-0.5 bg-accent-teal transform -translate-x-1/2 z-0"
        >
        </div>
        <div
          class="relative w-24 h-24 mx-auto mb-6 bg-accent-teal rounded-full flex flex-col items-center justify-center text-white shadow-lg z-10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-credit-card w-8 h-8 mb-1"
          >
            <rect width="20" height="14" x="2" y="5" rx="2"></rect>
            <line x1="2" x2="22" y1="10" y2="10"></line></svg
          ><span class="text-xs font-bold">01</span>
        </div>
        <h3
          class="text-2xl md:text-3xl font-bold mb-3 text-gray-900 dark:text-white"
        >
          Choose Your Plan
        </h3>
        <p
          class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed"
        >
          Select the plan that fits your needs. Start with our free trial.
        </p>
      </div>
      <div class="relative text-center z-10">
        <div
          class="hidden md:block absolute top-12 left-full w-full h-0.5 bg-accent-teal transform -translate-x-1/2 z-0"
        >
        </div>
        <div
          class="relative w-24 h-24 mx-auto mb-6 bg-accent-teal rounded-full flex flex-col items-center justify-center text-white shadow-lg z-10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-palette w-8 h-8 mb-1"
          >
            <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle>
            <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle>
            <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
            <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle>
            <path
              d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"
            ></path></svg
          ><span class="text-xs font-bold">02</span>
        </div>
        <h3
          class="text-2xl md:text-3xl font-bold mb-3 text-gray-900 dark:text-white"
        >
          Customize Your Site
        </h3>
        <p
          class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed"
        >
          Use our easy-to-use editor to customize your landing page.
        </p>
      </div>
      <div class="relative text-center z-10">
        <div
          class="relative w-24 h-24 mx-auto mb-6 bg-accent-teal rounded-full flex flex-col items-center justify-center text-white shadow-lg z-10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-rocket w-8 h-8 mb-1"
          >
            <path
              d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
            ></path>
            <path
              d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
            ></path>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path></svg
          ><span class="text-xs font-bold">03</span>
        </div>
        <h3
          class="text-2xl md:text-3xl font-bold mb-3 text-gray-900 dark:text-white"
        >
          Launch &amp; Grow
        </h3>
        <p
          class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed"
        >
          Publish your site and start converting visitors into customers.
        </p>
      </div>
    </div>
  </div>
</section>
