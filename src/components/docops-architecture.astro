---
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Section from "./ui/section.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);
const docops = t("docopsArchitecture");
---

<Section
  monoTitle={docops.monoTitle}
  title={docops.title}
  description={docops.description}
  contentClass="grid grid-cols-1 gap-8 lg:grid-cols-3"
>
  {
    docops.lanes.map((lane) => (
      <Card variant="subtle">
        <MonoTitle>{lane.title}</MonoTitle>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{lane.body}</p>
        <ul class="mt-4 space-y-2 text-sm text-[var(--color-peach-paper-copy)]">
          {lane.bullets.map((bullet) => (
            <li class="flex items-center gap-2">
              <span aria-hidden="true">•</span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </Card>
    ))
  }
</Section>
