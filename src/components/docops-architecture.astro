---
import Card from "./ui/card.astro";
import Title from "./ui/title.astro";

const lanes = [
  {
    title: "Business authors",
    body: "Drag/drop blocks, manage schema examples, and preview PDFs with inline expression evaluation.",
    bullets: [
      "Block library: text, tables, columns, clauses, headers, footers",
      "Undo/redo + autosave stacks",
      "Inline JSONata + GraalJS expression tester",
    ],
  },
  {
    title: "Developers",
    body: "Version templates in Git, run Testcontainers suites, and invoke the OpenAPI-render API from orchestrators.",
    bullets: [
      "CQRS commands for template + theme automation",
      "Adaptive batch jobs with job states and metrics",
      "Webhooks + storage adapters (S3, Azure, DMS)",
    ],
  },
  {
    title: "Platform ops",
    body: "Deploy Helm charts with Keycloak/OIDC, monitor renders, and promote versions across environments.",
    bullets: [
      "Multi-tenant isolation + RBAC memberships",
      "Environments per tenant (staging/production)",
      "Prometheus/OTel metrics + health probes",
    ],
  },
];

const pipeline = [
  {
    title: "Template service",
    note: "Variants · versions · JSON Schema · theming",
  },
  {
    title: "Generation engine",
    note: "iText Core · expression sandbox · token cascade",
  },
  {
    title: "Delivery",
    note: "Jobs API · storage bridges · problem+json errors",
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="eyebrow">DocOps architecture</p>
        <Title level={2} class="mt-4"> Everything from editor to render API runs on the same opinionated stack. </Title>
        <p class="mt-4 text-lg text-[var(--muted-text)]">
          Epistola Suite isn’t a generic CMS. It is a multi-tenant document platform: Lit/ProseMirror editor, template
          service built on CQRS, iText renderer, and REST/Helm deployment tooling. Each persona plugs into the layer
          they need without reimplementing the stack.
        </p>
        <div class="mt-10 space-y-6">
          {
            lanes.map((lane) => (
              <Card variant="subtle">
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-peach-paper-accent)]">
                  {lane.title}
                </p>
                <p class="mt-3 text-sm text-[var(--muted-text)]">{lane.body}</p>
                <ul class="mt-4 space-y-2 text-sm text-[var(--color-peach-paper-copy)]">
                  {lane.bullets.map((bullet) => (
                    <li class="flex gap-2">
                      <span aria-hidden="true">•</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            ))
          }
        </div>
      </div>
      <div>
        <Card variant="default" radius="3xl" padding="lg" shadow="md" class="relative overflow-hidden">
          <div class="absolute -top-16 right-0 h-32 w-32 rounded-full bg-[var(--color-peach-paper-border)] blur-3xl">
          </div>
          <div class="relative">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-peach-paper-chip-text)]">
              Render pipeline
            </p>
            <Title level={3} class="mt-3">Data ➝ Template ➝ PDF</Title>
            <div class="mt-6 space-y-6">
              {
                pipeline.map((stage, index) => (
                  <div class="relative rounded-2xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] p-5">
                    <div class="flex items-center justify-between">
                      <p class="text-sm font-semibold text-[var(--color-peach-paper-heading)]">{stage.title}</p>
                      <span class="text-xs font-semibold text-[var(--color-peach-paper-accent)]">Step {index + 1}</span>
                    </div>
                    <p class="mt-3 text-sm text-[var(--muted-text)]">{stage.note}</p>
                    {index < pipeline.length - 1 && (
                      <div class="mt-5 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
                        Next
                        <span aria-hidden="true">→</span>
                      </div>
                    )}
                  </div>
                ))
              }
            </div>
            <div
              class="mt-8 rounded-2xl border border-[var(--color-peach-paper-border-strong)] bg-[var(--color-peach-paper-surface-strong)] p-5 text-sm text-[var(--color-peach-paper-heading)]"
            >
              <p class="font-semibold">Observability</p>
              <p class="mt-2">
                Adaptive batch logging, Prometheus counters, and structured problem+json errors make renders auditable
                in any SIEM.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </div>
</section>
