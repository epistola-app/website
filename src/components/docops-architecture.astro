---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Section from "./ui/section.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const lanes = filterDataByLocale(items, lang, "docops-lane");
---

<Section
  monoTitle={t(lang, "docops.monoTitle")}
  title={t(lang, "docops.title")}
  description={t(lang, "docops.description")}
  contentClass="grid grid-cols-1 gap-8 lg:grid-cols-3"
>
  {
    lanes.map((lane) => (
      <Card variant="subtle">
        <MonoTitle>{lane.data.title}</MonoTitle>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{lane.data.body}</p>
        <ul class="mt-4 space-y-2 text-sm text-[var(--color-peach-paper-copy)]">
          {lane.data.bullets.map((bullet) => (
            <li class="flex items-center gap-2">
              <span aria-hidden="true">•</span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </Card>
    ))
  }
</Section>
