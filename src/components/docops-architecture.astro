---
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Section from "./ui/section.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const lanes = [
  {
    title: t(lang, "docops.lane.0.title"),
    body: t(lang, "docops.lane.0.body"),
    bullets: [
      t(lang, "docops.lane.0.bullet.0"),
      t(lang, "docops.lane.0.bullet.1"),
      t(lang, "docops.lane.0.bullet.2"),
    ],
  },
  {
    title: t(lang, "docops.lane.1.title"),
    body: t(lang, "docops.lane.1.body"),
    bullets: [
      t(lang, "docops.lane.1.bullet.0"),
      t(lang, "docops.lane.1.bullet.1"),
      t(lang, "docops.lane.1.bullet.2"),
    ],
  },
  {
    title: t(lang, "docops.lane.2.title"),
    body: t(lang, "docops.lane.2.body"),
    bullets: [
      t(lang, "docops.lane.2.bullet.0"),
      t(lang, "docops.lane.2.bullet.1"),
      t(lang, "docops.lane.2.bullet.2"),
    ],
  },
];
---

<Section
  monoTitle={t(lang, "docops.monoTitle")}
  title={t(lang, "docops.title")}
  description={t(lang, "docops.description")}
  contentClass="grid grid-cols-1 gap-8 lg:grid-cols-3"
>
  {
    lanes.map((lane) => (
      <Card variant="subtle">
        <MonoTitle>{lane.title}</MonoTitle>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{lane.body}</p>
        <ul class="mt-4 space-y-2 text-sm text-[var(--color-peach-paper-copy)]">
          {lane.bullets.map((bullet) => (
            <li class="flex items-center gap-2">
              <span aria-hidden="true">•</span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </Card>
    ))
  }
</Section>
