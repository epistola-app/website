---
import Section from "./ui/section.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);
const introVideo = t("introVideo");
---

<Section
  monoTitle={introVideo.monoTitle}
  title={introVideo.title}
  contentClass="mx-auto max-w-5xl"
>
  <div
    class="relative aspect-video w-full overflow-hidden rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] shadow-lg shadow-black/10 dark:shadow-black/35"
  >
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 text-center">
      <div
        class="flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface-soft)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="h-7 w-7 translate-x-0.5 text-[var(--color-peach-paper-accent)]"
        >
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <p class="text-sm text-(--muted-text)">{introVideo.comingSoon}</p>
    </div>
  </div>
</Section>
