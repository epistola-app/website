---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const reasons = filterDataByLocale(items, lang, "why-us");
---

<Section
  monoTitle={t(lang, "whyUs.monoTitle")}
  title={t(lang, "whyUs.title")}
  description={t(lang, "whyUs.description")}
  contentClass="mx-auto grid gap-8 md:grid-cols-2"
>
  {
    reasons.map((reason) => (
      <Card variant="subtle" padding="lg">
        <Title level={3}>{reason.data.title}</Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{reason.data.copy}</p>
      </Card>
    ))
  }
</Section>
