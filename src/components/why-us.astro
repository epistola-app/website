---

---

<section class="relative py-24 bg-white dark:bg-gray-900 overflow-hidden">
  <div class="absolute inset-0 opacity-5 dark:opacity-10">
    <div
      class="absolute inset-0"
      style="
                background-image: radial-gradient(
                  circle at 2px 2px,
                  currentColor 1px,
                  transparent 0
                );
                background-size: 40px 40px;
              "
    >
    </div>
  </div>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20">
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight tracking-tight"
      >
        <span
          class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 dark:from-white dark:via-gray-100 dark:to-white bg-clip-text text-transparent"
          >Why Choose</span
        ><br /><span class="text-accent-teal">SaaSKit?</span>
      </h2>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto font-light"
      >
        Everything you need to build, launch, and scale your SaaS business
      </p>
    </div>
    <div class="space-y-20 max-w-4xl mx-auto">
      <div class="flex items-start gap-6">
        <div class="shrink-0 w-16 h-16 text-accent-teal dark:text-accent-green">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-zap w-full h-full"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text leading-normal text-transparent"
          >
            Lightning Fast Performance
          </h3>
          <p
            class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 leading-relaxed"
          >
            Built with Astro for optimal performance. Your pages load instantly,
            providing an exceptional user experience that converts visitors into
            customers.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-6">
        <div class="flex-1">
          <h3
            class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text leading-normal text-transparent"
          >
            Enterprise-Grade Security
          </h3>
          <p
            class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 leading-relaxed"
          >
            Your data and your customers&#x27; data are protected with
            industry-leading security measures. Sleep well knowing your platform
            is secure.
          </p>
        </div>
        <div
          class="flex-shrink-0 w-16 h-16 text-accent-teal dark:text-accent-green"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-shield w-full h-full"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
            ></path>
          </svg>
        </div>
      </div>
      <div class="flex items-start gap-6">
        <div
          class="flex-shrink-0 w-16 h-16 text-accent-teal dark:text-accent-green"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-rocket w-full h-full"
          >
            <path
              d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
            ></path>
            <path
              d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
            ></path>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text leading-normal text-transparent"
          >
            Scale Without Limits
          </h3>
          <p
            class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 leading-relaxed"
          >
            Built to grow with your business. From startup to enterprise, our
            platform scales seamlessly to meet your needs.
          </p>
        </div>
      </div>
      <div class="flex items-start gap-6">
        <div class="flex-1">
          <h3
            class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text leading-normal text-transparent"
          >
            Beautiful Design Out of the Box
          </h3>
          <p
            class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 leading-relaxed"
          >
            Stunning, modern design that requires zero design skills. Customize
            colors and content to match your brand in minutes.
          </p>
        </div>
        <div
          class="flex-shrink-0 w-16 h-16 text-accent-teal dark:text-accent-green"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-sparkles w-full h-full"
          >
            <path
              d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
            ></path>
            <path d="M5 3v4"></path>
            <path d="M19 17v4"></path>
            <path d="M3 5h4"></path>
            <path d="M17 19h4"></path>
          </svg>
        </div>
      </div>
    </div>
    <div
      class="mt-32 grid md:grid-cols-2 lg:grid-cols-3 place-items-center gap-8"
    >
      <div class="flex items-start gap-6">
        <div class="shrink-0 w-8 h-8 text-accent-teal dark:text-accent-green">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-trending-up w-full h-full"
          >
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
            <polyline points="16 7 22 7 22 13"></polyline>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="text-xl md:text-2xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text text-transparent"
          >
            99.9% Uptime
          </h3>
          <p class="text-base text-gray-700 dark:text-gray-300 leading-relaxed">
            Reliable infrastructure
          </p>
        </div>
      </div>
      <div class="flex items-start gap-6">
        <div
          class="flex-shrink-0 w-8 h-8 text-accent-teal dark:text-accent-green"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-users w-full h-full"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="text-xl md:text-2xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text text-transparent"
          >
            10K+ Users
          </h3>
          <p class="text-base text-gray-700 dark:text-gray-300 leading-relaxed">
            Trusted by thousands
          </p>
        </div>
      </div>
      <div class="flex items-start gap-6">
        <div
          class="flex-shrink-0 w-8 h-8 text-accent-teal dark:text-accent-green"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-zap w-full h-full"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <div class="flex-1">
          <h3
            class="text-xl md:text-2xl font-bold mb-3 bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-200 bg-clip-text text-transparent"
          >
            24/7 Support
          </h3>
          <p class="text-base text-gray-700 dark:text-gray-300 leading-relaxed">
            Always here to help
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
