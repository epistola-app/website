---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const reasons = [
  {
    title: t(lang, "whyUs.reason.0.title"),
    copy: t(lang, "whyUs.reason.0.copy"),
  },
  {
    title: t(lang, "whyUs.reason.1.title"),
    copy: t(lang, "whyUs.reason.1.copy"),
  },
  {
    title: t(lang, "whyUs.reason.2.title"),
    copy: t(lang, "whyUs.reason.2.copy"),
  },
  {
    title: t(lang, "whyUs.reason.3.title"),
    copy: t(lang, "whyUs.reason.3.copy"),
  },
];
---

<Section
  monoTitle={t(lang, "whyUs.monoTitle")}
  title={t(lang, "whyUs.title")}
  description={t(lang, "whyUs.description")}
  contentClass="mx-auto grid gap-8 md:grid-cols-2"
>
  {
    reasons.map((reason) => (
      <Card variant="subtle" padding="lg">
        <Title level={3}>{reason.title}</Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{reason.copy}</p>
      </Card>
    ))
  }
</Section>
