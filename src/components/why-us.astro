---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { useTranslations } from "../i18n";

const { t } = useTranslations(Astro);
const whyUs = t("whyUs");
---

<Section
  monoTitle={whyUs.monoTitle}
  title={whyUs.title}
  description={whyUs.description}
  contentClass="mx-auto grid gap-8 md:grid-cols-2"
>
  {
    whyUs.reasons.map((reason) => (
      <Card variant="subtle" padding="lg">
        <Title level={3}>{reason.title}</Title>
        <p class="mt-3 text-sm text-[var(--muted-text)]">{reason.copy}</p>
      </Card>
    ))
  }
</Section>
