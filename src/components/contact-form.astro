---
import { Mail, Phone, Video } from "@lucide/astro";
import { useTranslations } from "../i18n";
import Button from "./ui/button.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const { t } = useTranslations(Astro);
const contactForm = t("contactForm");

const inputClasses =
  "w-full rounded-none border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-4 py-2.5 text-sm text-[var(--color-peach-paper-heading)] placeholder:text-[var(--color-peach-paper-chip-text)] focus:border-[var(--color-peach-paper-border-strong)] focus:outline-none";

const labelClasses = "text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-peach-paper-chip-text)]";

const toggleClasses =
  "contact-toggle flex cursor-pointer items-center gap-2 border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-4 py-2.5 text-sm text-[var(--color-peach-paper-copy)] transition-colors hover:border-[var(--color-peach-paper-border-strong)] has-checked:border-[var(--color-peach-paper-accent)] has-checked:bg-[var(--color-peach-paper-surface)] has-checked:text-[var(--color-peach-paper-accent)] has-[:focus-visible]:outline has-[:focus-visible]:outline-2 has-[:focus-visible]:outline-offset-2 has-[:focus-visible]:outline-[var(--color-peach-paper-accent)]";
---

<div
  class:list={["contact-form", className]}
  data-contact-type="email"
  data-slot-placeholder={contactForm.slotPlaceholder}
  data-error-select-contact-type={contactForm.errors.selectContactType}
  data-error-select-time-slots={contactForm.errors.selectTimeSlots}
  data-error-complete-verification={contactForm.errors.completeVerification}
  data-error-generic-prefix={contactForm.errors.genericPrefix}
  data-error-generic-link-text={contactForm.errors.genericLinkText}
>
  <form data-contact-form class="flex flex-col gap-5">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="flex flex-col gap-1.5">
        <span class={labelClasses}>
          {contactForm.nameLabel}
          <span class="text-(--color-peach-paper-accent)">*</span>
        </span>
        <input
          type="text"
          name="name"
          autocomplete="name"
          required
          placeholder={contactForm.namePlaceholder}
          class={inputClasses}
        />
      </label>
      <label class="flex flex-col gap-1.5">
        <span class={labelClasses}>
          {contactForm.emailLabel}
          <span class="text-(--color-peach-paper-accent)">*</span>
        </span>
        <input
          type="email"
          name="email"
          autocomplete="email"
          required
          placeholder={contactForm.emailPlaceholder}
          class={inputClasses}
        />
      </label>
    </div>

    <fieldset class="flex flex-col gap-1.5">
      <legend class={labelClasses}>
        {contactForm.contactTypeLabel}
        <span class="text-(--color-peach-paper-accent)">*</span>
      </legend>
      <div class="flex flex-wrap gap-3">
        <label class={toggleClasses}>
          <input class="sr-only" type="radio" name="contactTypeChoice" value="email" checked />
          <Mail class="h-4 w-4" />
          <span>{contactForm.contactTypeEmail}</span>
        </label>
        <label class={toggleClasses}>
          <input class="sr-only" type="radio" name="contactTypeChoice" value="phone" />
          <Phone class="h-4 w-4" />
          <span>{contactForm.contactTypePhone}</span>
        </label>
        <label class={toggleClasses}>
          <input class="sr-only" type="radio" name="contactTypeChoice" value="video" />
          <Video class="h-4 w-4" />
          <span>{contactForm.contactTypeVideo}</span>
        </label>
      </div>
      <input type="hidden" name="contactType" value="email" />
    </fieldset>

    <!-- Call details (shown when phone or video is selected) -->
    <div data-call-details class="hidden flex flex-col gap-4">
      <!-- Phone number (shown only for phone calls) -->
      <label data-phone-field class="flex flex-col gap-1.5">
        <span class={labelClasses}>
          {contactForm.phoneLabel}
          <span class="text-(--color-peach-paper-accent)">*</span>
        </span>
        <input
          type="tel"
          name="phone"
          autocomplete="tel"
          placeholder={contactForm.phonePlaceholder}
          class={inputClasses}
        />
      </label>

      <!-- Time slot dropdowns (populated by JS) -->
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1.5">
          <span class={labelClasses}>
            {contactForm.preferredTimeLabel}
            <span class="text-(--color-peach-paper-accent)">*</span>
          </span>
          <select name="preferredSlot" class={inputClasses + " slot-select"}>
            <option value="">{contactForm.slotPlaceholder}</option>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class={labelClasses}>
            {contactForm.backupTimeLabel}
            <span class="text-(--color-peach-paper-accent)">*</span>
          </span>
          <select name="backupSlot" class={inputClasses + " slot-select"}>
            <option value="">{contactForm.slotPlaceholder}</option>
          </select>
        </label>
      </div>
    </div>

    <!-- Message (always visible) -->
    <label class="flex flex-col gap-1.5">
      <span class={labelClasses}>{contactForm.messageLabel}</span>
      <textarea
        name="message"
        rows="3"
        placeholder={contactForm.messagePlaceholder}
        class={inputClasses + " resize-y min-h-20 max-h-50"}></textarea>
    </label>

    <div>
      <altcha-widget challengeurl="https://automation.cs.epistola.io/api/r/captcha" hidefooter data-altcha
      ></altcha-widget>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
      <Button type="submit" variant="primary" size="md" class="w-full sm:w-auto">
        {contactForm.submit}
      </Button>
      <p data-contact-error class="hidden text-sm text-(--color-danger-500)"></p>
    </div>
  </form>

  <div data-contact-success class="hidden text-center py-6">
    <p class="text-lg font-semibold text-(--color-peach-paper-heading)">
      {contactForm.successTitle}
    </p>
    <p class="mt-2 text-sm text-(--color-peach-paper-copy)">
      {contactForm.successDescription}
    </p>
  </div>
</div>

<script>
  import "altcha";

  function generateSlots(): { value: string; label: string }[] {
    const slots: { value: string; label: string }[] = [];
    const locale = navigator.language || "en";
    const dateFmt = new Intl.DateTimeFormat(locale, { weekday: "short", day: "numeric", month: "short" });
    const timeFmt = new Intl.DateTimeFormat(locale, { hour: "2-digit", minute: "2-digit" });

    const now = new Date();
    const minTime = new Date(now.getTime() + 3 * 60 * 60 * 1000);
    const maxTime = new Date(now.getTime() + 14 * 24 * 60 * 60 * 1000);

    const cursor = new Date(minTime);
    cursor.setMinutes(cursor.getMinutes() < 30 ? 30 : 0, 0, 0);
    if (cursor.getMinutes() === 0) cursor.setHours(cursor.getHours() + 1);

    while (cursor <= maxTime) {
      const day = cursor.getDay();
      const hour = cursor.getHours();
      const mins = cursor.getMinutes();

      if (day >= 1 && day <= 5 && hour >= 8 && (hour < 17 || (hour === 17 && mins <= 30))) {
        const iso = cursor.toISOString();
        const label = `${dateFmt.format(cursor)} — ${timeFmt.format(cursor)}`;
        slots.push({ value: iso, label });
      }

      cursor.setMinutes(cursor.getMinutes() + 30);
    }

    return slots;
  }

  function populateSlotDropdowns(wrapper: HTMLElement) {
    const slots = generateSlots();
    const slotPlaceholder = wrapper.dataset.slotPlaceholder || "Select a time slot";

    wrapper.querySelectorAll<HTMLSelectElement>(".slot-select").forEach((select) => {
      const firstOption = select.querySelector("option");
      if (firstOption) {
        firstOption.textContent = slotPlaceholder;
      }

      slots.forEach(({ value, label }) => {
        const opt = document.createElement("option");
        opt.value = value;
        opt.textContent = label;
        select.appendChild(opt);
      });
    });
  }

  function initContactForms() {
    document.querySelectorAll<HTMLElement>(".contact-form").forEach((wrapper) => {
      if (wrapper.dataset.initialized) return;
      wrapper.dataset.initialized = "true";

      const form = wrapper.querySelector<HTMLFormElement>("[data-contact-form]");
      const successEl = wrapper.querySelector<HTMLElement>("[data-contact-success]");
      const errorEl = wrapper.querySelector<HTMLElement>("[data-contact-error]");
      if (!form || !successEl || !errorEl) return;

      const contactTypeInput = form.querySelector<HTMLInputElement>('input[name="contactType"]')!;
      const callDetails = form.querySelector<HTMLElement>("[data-call-details]")!;
      const phoneField = form.querySelector<HTMLElement>("[data-phone-field]")!;
      const phoneInput = form.querySelector<HTMLInputElement>('input[name="phone"]')!;
      const contactTypeRadios = form.querySelectorAll<HTMLInputElement>('input[name="contactTypeChoice"]');
      const selectContactTypeError =
        wrapper.dataset.errorSelectContactType || "Please select how you'd like to connect.";
      const selectTimeSlotsError =
        wrapper.dataset.errorSelectTimeSlots || "Please select both a preferred and backup time slot.";
      const completeVerificationError =
        wrapper.dataset.errorCompleteVerification || "Please complete the verification challenge.";
      const genericErrorPrefix =
        wrapper.dataset.errorGenericPrefix || "Something went wrong. Please try again or reach out to";
      const genericErrorLinkText = wrapper.dataset.errorGenericLinkText || "sander@epistola.app";

      populateSlotDropdowns(wrapper);

      function showGenericError() {
        errorEl?.replaceChildren(document.createTextNode(`${genericErrorPrefix} `));

        const link = document.createElement("a");
        link.href = "mailto:sander@epistola.app";
        link.className = "underline text-[var(--color-peach-paper-accent)]";
        link.textContent = genericErrorLinkText;

        errorEl?.append(link, document.createTextNode("."));
        errorEl?.classList.remove("hidden");
      }

      function updateFields() {
        const type = contactTypeInput.value;
        const isCall = type === "phone" || type === "video";

        if (isCall) {
          callDetails.classList.remove("hidden");
        } else {
          callDetails.classList.add("hidden");
          phoneInput.required = false;
        }

        if (type === "phone") {
          phoneField.classList.remove("hidden");
          phoneInput.required = true;
        } else {
          phoneField.classList.add("hidden");
          phoneInput.required = false;
          phoneInput.value = "";
        }
      }

      function syncContactType(type: string) {
        contactTypeInput.value = type;
        wrapper.dataset.contactType = type;
        updateFields();
      }

      const selectedContactType = Array.from(contactTypeRadios).find((radio) => radio.checked)?.value || "email";
      syncContactType(selectedContactType);

      contactTypeRadios.forEach((radio) => {
        radio.addEventListener("change", () => {
          if (!radio.checked) return;
          syncContactType(radio.value);
        });
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.classList.add("hidden");

        if (!contactTypeInput.value) {
          errorEl.textContent = selectContactTypeError;
          errorEl.classList.remove("hidden");
          return;
        }

        if (contactTypeInput.value === "phone" || contactTypeInput.value === "video") {
          const pref = (form.elements.namedItem("preferredSlot") as HTMLSelectElement).value;
          const back = (form.elements.namedItem("backupSlot") as HTMLSelectElement).value;
          if (!pref || !back) {
            errorEl.textContent = selectTimeSlotsError;
            errorEl.classList.remove("hidden");
            return;
          }
        }

        const altchaInput = wrapper.querySelector<HTMLInputElement>('[name="altcha"]');
        const altchaPayload = altchaInput?.value;
        if (!altchaPayload) {
          errorEl.textContent = completeVerificationError;
          errorEl.classList.remove("hidden");
          return;
        }

        const data: Record<string, string | undefined> = {
          name: (form.elements.namedItem("name") as HTMLInputElement).value,
          email: (form.elements.namedItem("email") as HTMLInputElement).value,
          contactType: contactTypeInput.value,
          message: (form.elements.namedItem("message") as HTMLTextAreaElement).value || undefined,
          altcha: altchaPayload,
        };

        if (contactTypeInput.value === "phone" || contactTypeInput.value === "video") {
          data.preferredTime = (form.elements.namedItem("preferredSlot") as HTMLSelectElement).value;
          data.backupTime = (form.elements.namedItem("backupSlot") as HTMLSelectElement).value;
          if (contactTypeInput.value === "phone") {
            data.phone = phoneInput.value;
          }
        }

        try {
          const res = await fetch("https://automation.cs.epistola.io/api/r/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          if (!res.ok) throw new Error("Request failed");

          form.classList.add("hidden");
          successEl.classList.remove("hidden");
        } catch {
          showGenericError();
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initContactForms);
  initContactForms();
</script>
