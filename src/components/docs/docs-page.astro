---
import { getCollection } from "astro:content";
import DocsNav from "./docs-nav.astro";
import Title from "../ui/title.astro";
import { t, localePath, filterByLocale, type Locale, DEFAULT_LOCALE } from "../../i18n";

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  lang?: Locale;
}

const { title, description, currentSlug, lang = DEFAULT_LOCALE } = Astro.props;

// Reverse-link: find learn units whose deepLinks point to this docs page
const docsPath = `/${lang}/docs/${currentSlug}`;
const allLearn = await getCollection("learn");
const localeLearn = filterByLocale(allLearn, lang);
const relatedLearnUnits = localeLearn.filter((unit) =>
  unit.data.deepLinks?.some((link: { url: string }) => link.url === docsPath)
);
---

<div class="pt-32 pb-20">
  <div class="container mx-auto px-4">
    <div class="mx-auto max-w-7xl">
      <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-10">
        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-32">
            <DocsNav lang={lang} currentSlug={currentSlug} />
          </div>
        </aside>

        <!-- Content -->
        <div class="mx-auto max-w-3xl">
          <header class="mb-8">
            <a
              href={localePath(lang, "/docs")}
              class="mb-4 inline-block text-sm font-semibold text-[var(--color-peach-paper-accent)] hover:underline"
            >
              {t(lang, "docs.backToDocs")}
            </a>
            <Title level={1} class="mb-4 font-black leading-tight">
              {title}
            </Title>
            <p class="text-lg text-[var(--muted-text)]">{description}</p>
          </header>

          <div class="prose prose-lg dark:prose-invert max-w-none">
            <slot />
          </div>

          {
            relatedLearnUnits.length > 0 && (
              <div class="mt-12 border-t border-[var(--color-peach-paper-border)] pt-8">
                <Title level={3} class="mb-4 text-lg font-bold">
                  {t(lang, "docs.seeInAction")}
                </Title>
                <div class="flex flex-wrap gap-3">
                  {relatedLearnUnits.map((unit) => {
                    const unitSlug = unit.slug.replace(`${lang}/`, "");
                    return (
                      <a
                        href={localePath(lang, `/learn/${unitSlug}?mode=explore`)}
                        class="inline-flex items-center gap-1.5 rounded-md border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] px-3 py-1.5 text-sm font-medium text-[var(--color-peach-paper-accent)] transition-colors hover:border-[var(--color-peach-paper-border-strong)] hover:bg-[var(--color-peach-paper-surface-soft)]"
                      >
                        {unit.data.title} &rarr;
                      </a>
                    );
                  })}
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</div>
