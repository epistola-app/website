---
import Button from "./ui/button.astro";
import HeaderNavLink from "./ui/header-nav-link.astro";
import ThemeToggle from "./ui/theme-toggle.astro";

const navItems = [
  { label: "Platform", href: "/features" },
  { label: "Integrations", href: "/integrations" },
  { label: "Pricing", href: "/pricing" },
  { label: "Docs", href: "https://docs.epistola.app", external: true },
  { label: "Blog", href: "/blog" },
];

const logoHref = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-[var(--color-peach-paper-nav-border)] backdrop-blur-xl"
>
  <div
    class="absolute inset-0 [background-image:var(--gradient-peach-paper)] opacity-95"
  >
  </div>
  <nav
    class="relative z-10 mx-auto flex h-20 max-w-6xl items-center justify-between px-4"
  >
    <a href={logoHref} class="flex items-center gap-3">
      <div
        class="flex h-10 w-10 items-center justify-center rounded-xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] font-semibold text-[var(--color-peach-paper-heading)]"
      >
        E
      </div>
      <div class="flex flex-col">
        <span
          class="text-base font-semibold tracking-tight text-[var(--color-peach-paper-heading)]"
        >
          Epistola
        </span>
        <span
          class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-peach-paper-copy)]"
          >Documents</span
        >
      </div>
    </a>
    <button
      id="nav-toggle"
      class="md:hidden flex h-11 w-11 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] text-[var(--color-peach-paper-heading)]"
      aria-controls="mobile-nav"
      aria-expanded="false"
    >
      <span class="sr-only">Open navigation</span>
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 7h16M4 12h12M4 17h16"></path>
      </svg>
    </button>
    <div
      class="hidden items-center gap-8 text-sm font-medium text-[var(--color-peach-paper-copy)] md:flex"
    >
      {
        navItems.map((item) => (
          <HeaderNavLink {...item} currentPath={currentPath} />
        ))
      }
    </div>
    <div class="hidden items-center gap-3 md:flex">
      <ThemeToggle />
      <Button href="/login" variant="secondary" size="md"> Sign in </Button>
      <Button
        href="https://demo.epistola.app"
        variant="primary"
        size="md"
        external
      >
        Open demo
      </Button>
    </div>
    <div
      id="mobile-nav"
      class="fixed inset-y-0 right-0 z-50 hidden w-80 max-w-full border-l border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-surface)] p-6 shadow-2xl md:hidden"
    >
      <div class="flex items-center justify-between">
        <p class="text-sm font-semibold text-[var(--color-peach-paper-copy)]">
          Menu
        </p>
        <button
          id="nav-close"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] text-[var(--color-peach-paper-heading)]"
          aria-label="Close navigation"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            fill="none"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m6 6 12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <div class="mt-8 flex flex-col gap-4 text-lg font-medium">
        {
          navItems.map((item) => (
            <HeaderNavLink {...item} mobile currentPath={currentPath} />
          ))
        }
      </div>
      <div class="mt-8 flex flex-col gap-3">
        <Button
          href="/login"
          variant="secondary"
          size="lg"
          class="w-full justify-center"
        >
          Sign in
        </Button>
        <Button
          href="https://demo.epistola.app"
          variant="primary"
          size="lg"
          class="w-full justify-center"
          external
        >
          Open demo
        </Button>
      </div>
      <ThemeToggle mobile class="mt-8" />
    </div>
    <div id="scrim" class="fixed inset-0 z-40 hidden bg-black/30"></div>
  </nav>
</header>

<script>
  const scrim = document.getElementById("scrim");
  const openBtn = document.getElementById("nav-toggle");
  const drawer = document.getElementById("mobile-nav");
  const closeBtn = document.getElementById("nav-close");

  const openDrawer = () => {
    drawer?.classList.remove("hidden");
    scrim?.classList.remove("hidden");
    openBtn?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeDrawer = () => {
    drawer?.classList.add("hidden");
    scrim?.classList.add("hidden");
    openBtn?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  openBtn?.addEventListener("click", openDrawer);
  closeBtn?.addEventListener("click", closeDrawer);
  scrim?.addEventListener("click", closeDrawer);

  drawer
    ?.querySelectorAll("a")
    .forEach((link) => link.addEventListener("click", closeDrawer));

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeDrawer();
    }
  });
</script>
