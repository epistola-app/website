---
import Button from "./ui/button.astro";
import HeaderNavLink from "./ui/header-nav-link.astro";
import ThemeToggle from "./ui/theme-toggle.astro";
import SuiteDemoButton from "./buttons/suite-demo-button.astro";
import { URLS } from "../lib/URL-helpers";

const navItems = [
  { label: "Platform", href: "/features" },
  { label: "Integrations", href: "/integrations" },
  { label: "Pricing", href: "/pricing" },
  { label: "Docs", href: "/docs" },
  { label: "Blog", href: "/blog" },
];

const logoHref = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header
  class="sticky inset-x-0 left-0 top-0 z-50 border-b border-[var(--color-peach-paper-nav-border)] backdrop-blur-xl"
>
  <div class="absolute inset-0 [background-image:var(--gradient-peach-paper)] opacity-95"></div>
  <nav class="relative z-10 container mx-auto flex h-20 items-center justify-between px-4">
    <a href={logoHref} class="flex items-center gap-3">
      <img src="/logo.svg" alt="Epistola logo" class="h-10 w-10" />
      <div class="flex flex-col">
        <span class="text-base font-semibold tracking-tight text-[var(--color-peach-paper-heading)]"> Epistola </span>
        <span class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-peach-paper-copy)]">Documents</span>
      </div>
    </a>
    <button
      id="nav-toggle"
      class="lg:hidden flex h-11 w-11 items-center justify-center rounded-none border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] text-[var(--color-peach-paper-heading)]"
      aria-controls="mobile-nav"
      aria-expanded="false"
      command="show-modal"
      commandfor="mobile-nav"
    >
      <span class="sr-only">Open navigation</span>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h12M4 17h16"></path>
      </svg>
    </button>
    <div class="hidden items-center gap-8 text-sm font-medium text-[var(--color-peach-paper-copy)] lg:flex">
      {navItems.map((item) => <HeaderNavLink {...item} currentPath={currentPath} />)}
    </div>
    <div class="hidden items-center gap-3 lg:flex">
      <ThemeToggle />
      <SuiteDemoButton />
    </div>
    <dialog
      id="mobile-nav"
      class="mobile-drawer m-0 z-70 lg:hidden w-full max-w-screen h-full max-h-screen"
      aria-label="Mobile navigation"
    >
      <div class="flex h-22 p-4 items-center justify-between">
        <p class="text-sm font-semibold uppercase font-[family-name:var(--font-mono)] tracking-wider text-[var(--color-peach-paper-copy)]">
          Menu
        </p>
        <button
          id="nav-close"
          class="flex h-10 w-10 items-center justify-center rounded-none border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] text-[var(--color-peach-paper-heading)]"
          aria-label="Close navigation"
          command="close"
          commandfor="mobile-nav"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" fill="none">
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 6 12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <div class="mt-8 flex p-4 flex-col gap-4">
        {navItems.map((item) => <HeaderNavLink {...item} mobile currentPath={currentPath} />)}
      </div>
      <div class="mt-8 p-4 flex flex-col gap-3">
        <SuiteDemoButton />
      </div>
      <ThemeToggle mobile class="mt-8 p-4" />
    </dialog>
  </nav>
</header>
