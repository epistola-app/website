---
import { prepareURL } from "../lib/URL-helpers";

const navItems = [
  { label: "Features", href: "features" },
  { label: "Pricing", href: "pricing" },
  { label: "Integrations", href: "integrations" },
  { label: "Blog", href: "blog" },
  { label: "Docs", href: "docs" },
];

const ctaItems = [
  { label: "Login", href: "login" },
  { label: "Get Started", href: "register", primary: true },
];

const logoHref = import.meta.env.BASE_URL;
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <!-- Background with blur effect -->
  <div
    class="absolute inset-0 bg-white/80 dark:bg-accent-dark/80 backdrop-blur-xl transition-all duration-300"
    id="header-bg"
  >
  </div>
  <!-- Subtle pattern overlay -->
  <div
    class="absolute inset-0 opacity-5 dark:opacity-10"
    style="
          background-image: repeating-linear-gradient(
              0deg,
              rgba(5, 94, 104, 0.1) 0 1px,
              transparent 1px 20px
            ),
            repeating-linear-gradient(
              90deg,
              rgba(5, 94, 104, 0.1) 0 1px,
              transparent 1px 20px
            );
          background-size: 20px 20px;
        "
  >
  </div>
  <!-- Floating decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Floating circle 1 -->
    <div
      class="absolute top-0 right-1/4 w-32 h-32 bg-accent-teal/10 rounded-full blur-2xl animate-float"
      style="animation-delay: 0s; animation-duration: 6s"
    >
    </div>
    <!-- Floating circle 2 -->
    <div
      class="absolute top-0 left-1/3 w-24 h-24 bg-accent-green/10 rounded-full blur-2xl animate-float"
      style="animation-delay: 2s; animation-duration: 8s"
    >
    </div>
    <!-- Floating circle 3 -->
    <div
      class="absolute top-0 right-1/2 w-20 h-20 bg-accent-light/20 rounded-full blur-xl animate-float"
      style="animation-delay: 4s; animation-duration: 7s"
    >
    </div>
  </div>
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={logoHref}
        class="flex items-center space-x-2 group relative z-10"
      >
        <div
          class="w-8 h-8 bg-accent-dark dark:bg-accent-teal rounded-lg flex items-center justify-center group-hover:scale-105 transition-transform shadow-sm"
        >
          <span class="text-accent-light dark:text-white font-bold text-lg"
            >S</span
          >
        </div>
        <span
          class="text-xl font-semibold text-accent-dark dark:text-accent-light"
        >
          SaaSKit
        </span>
      </a>
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {
          navItems.map((item) => (
            <a
              href={prepareURL(item.href)}
              class="text-accent-dark dark:text-accent-light/90 hover:text-accent-dark dark:hover:text-accent-light transition-colors font-medium text-sm relative group"
            >
              {item.label}
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent-teal group-hover:w-full transition-all duration-300" />
            </a>
          ))
        }
      </div>
      <!-- Right side actions -->
      <div class="flex items-center space-x-4">
        <!-- Dark/Light Mode -->

        <button
          class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Toggle dark mode"
        >
          <div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-moon w-5 h-5 text-gray-700 dark:text-gray-300"
            >
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </div>
        </button>
        {
          ctaItems.map((item) => (
            <a
              href={prepareURL(item.href)}
              class:list={[
                item.primary
                  ? "hidden sm:inline-block px-5 py-2 bg-black dark:bg-white text-white dark:text-black rounded-lg hover:bg-black/90 dark:hover:bg-white/90 transition-all font-medium text-sm shadow-sm hover:shadow-md"
                  : "hidden sm:inline-block text-accent-dark dark:text-accent-light/90 hover:text-accent-dark dark:hover:text-accent-light transition-colors font-medium text-sm",
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle menu"
        >
          <svg
            class="w-6 h-6 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            id="hamburger-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="w-6 h-6 hidden transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            id="close-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-gray-200 dark:border-gray-800 mt-2 pt-4"
    >
      <div class="flex flex-col space-y-3">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-accent-dark dark:text-accent-light/90 hover:text-accent-dark dark:hover:text-accent-light transition-colors font-medium py-2"
            >
              {item.label}
            </a>
          ))
        }
        {
          ctaItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                item.primary
                  ? "px-4 py-2 bg-black dark:bg-white text-white dark:text-black rounded-lg hover:bg-black/90 dark:hover:bg-white/90 transition-all font-medium text-center"
                  : "text-accent-dark dark:text-accent-light/90 hover:text-accent-dark dark:hover:text-accent-light transition-colors font-medium py-2",
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  const menuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;

    menuButton?.setAttribute("aria-expanded", isOpen.toString());

    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    menuButton?.setAttribute("aria-expanded", "false");
    hamburgerIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  menuButton?.addEventListener("click", toggleMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("click", (e) => {
    if (
      !menuButton?.contains(e.target as Node) &&
      !mobileMenu?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeMenu();
    }
  });
</script>
