---
import { ArrowRight } from "@lucide/astro";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Title from "./ui/title.astro";
import Button from "./ui/button.astro";
import Section from "./ui/section.astro";

const cardVariants = ["subtle", "default", "brand"] as const;

const features = [
  {
    title: "Template lifecycle",
    body: "Variants, immutable versions, and draft/publish/archived states per tenant with audit trails and schema migrations.",
    badge: "Templates",
    href: "/features#template-system",
  },
  {
    title: "Visual editor",
    body: "Drag-and-drop blocks with conditional logic, loops, live PDF preview, and inline expression chips.",
    badge: "Authoring",
    href: "/features#feature-breakdown",
  },
  {
    title: "Expression engine",
    body: "Use flexible expressions to calculate totals, format values, and apply conditional logic. Define input variables per template.",
    badge: "Logic",
    href: "/features#feature-breakdown",
  },
  {
    title: "Direct PDF renderer",
    body: "Render PDF/A and PDF/X outputs directly — no HTML conversion step. Handles 10,000+ documents per minute on simple hardware.",
    badge: "Rendering",
    href: "/features#feature-breakdown",
  },
  {
    title: "Multi-tenant governance",
    body: "Role-based access, environment promotions (staging/production), and per-tenant default themes keep teams isolated.",
    badge: "Operations",
    href: "/features#feature-breakdown",
  },
  {
    title: "API + jobs",
    body: "OpenAPI 3.1 REST endpoints for single or batch renders with adaptive job sizing, webhooks, and storage adapters.",
    badge: "Delivery",
    href: "/features#feature-breakdown",
  },
];
---

<Section
  monoTitle="/ Everything you need to render PDFs"
  title="Epistola does templates and rendering — nothing else."
  description="Keep workflows in the products that orchestrate your cases while Epistola focuses on perfect output."
  contentClass="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
>
  {
    features.map((feature, index) => (
      <Card variant={cardVariants[index % cardVariants.length]} shadow="none" class="relative overflow-hidden">
        <MonoTitle>{feature.badge}</MonoTitle>
        <Title level={3} class="mt-4">
          {feature.title}
        </Title>
        <p class="mt-3 text-sm text-(--muted-text)">{feature.body}</p>
        <Button variant="primary" size="sm" class="group mt-6 flex items-center gap-2" href={feature.href}>
          Learn more
          {/* <span aria-hidden="true">→</span> */}
          <ArrowRight size={16} class="transition-transform group-hover:translate-x-1.5" />
        </Button>
      </Card>
    ))
  }
</Section>
