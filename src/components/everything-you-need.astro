---

<section class="relative py-20 bg-white dark:bg-gray-900 overflow-hidden">
  <div class="absolute inset-0 opacity-30 dark:opacity-10">
    <div
      class="absolute inset-0"
      style="
                background-image: radial-gradient(
                  circle at 2px 2px,
                  currentColor 1px,
                  transparent 0
                );
                background-size: 40px 40px;
              "
    >
    </div>
  </div>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight tracking-tight"
      >
        <span
          class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 dark:from-white dark:via-gray-100 dark:to-white bg-clip-text text-transparent"
          >Everything you need to</span
        ><br /><span class="text-accent-teal">launch your SaaS</span>
      </h2>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto font-light leading-relaxed"
      >
        Packed with features that help you convert visitors into customers.
        Beautiful design meets powerful functionality.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div
        class="group relative p-6 bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200/50 dark:border-white/10 rounded-2xl hover:shadow-xl transition-all"
        style="
                  box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.1);
                "
      >
        <div
          class="absolute inset-0 rounded-2xl bg-accent-teal opacity-0 group-hover:opacity-10 transition-opacity -z-10"
        >
        </div>
        <div
          class="w-14 h-14 mb-4 bg-accent-teal rounded-xl flex items-center justify-center shadow-lg"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-zap w-7 h-7 text-white"
          >
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <h3
          class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3"
        >
          Lightning Fast
        </h3>
        <p
          class="text-base md:text-lg text-gray-600 dark:text-gray-400 leading-relaxed"
        >
          Built with Astro for optimal performance and SEO. Your pages load
          instantly.
        </p>
      </div>
      <div
        class="group relative p-6 bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200/50 dark:border-white/10 rounded-2xl hover:shadow-xl transition-all"
        style="
                  box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.1);
                "
      >
        <div
          class="absolute inset-0 rounded-2xl bg-accent-green opacity-0 group-hover:opacity-10 transition-opacity -z-10"
        >
        </div>
        <div
          class="w-14 h-14 mb-4 bg-accent-green rounded-xl flex items-center justify-center shadow-lg"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-palette w-7 h-7 text-white"
          >
            <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle>
            <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle>
            <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle>
            <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle>
            <path
              d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"
            ></path>
          </svg>
        </div>
        <h3
