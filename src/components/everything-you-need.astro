---
import { getCollection } from "astro:content";
import { ArrowRight } from "@lucide/astro";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Title from "./ui/title.astro";
import Button from "./ui/button.astro";
import Section from "./ui/section.astro";
import { t, localePath, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const cardVariants = ["subtle", "default", "brand"] as const;

const items = await getCollection("product");
const featureCards = filterDataByLocale(items, lang, "feature-card");

const featureHrefs = [
  localePath(lang, "/features#template-system"),
  localePath(lang, "/features#feature-breakdown"),
  localePath(lang, "/features#feature-breakdown"),
  localePath(lang, "/features#feature-breakdown"),
  localePath(lang, "/features#feature-breakdown"),
  localePath(lang, "/features#feature-breakdown"),
];
---

<Section
  monoTitle={t(lang, "everything.monoTitle")}
  title={t(lang, "everything.title")}
  description={t(lang, "everything.description")}
  contentClass="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
>
  {
    featureCards.map((feature, index) => (
      <Card variant={cardVariants[index % cardVariants.length]} shadow="none" class="relative overflow-hidden">
        <MonoTitle>{feature.data.badge}</MonoTitle>
        <Title level={3} class="mt-4">
          {feature.data.title}
        </Title>
        <p class="mt-3 text-sm text-(--muted-text)">{feature.data.body}</p>
        <Button variant="primary" size="sm" class="group mt-6 flex items-center gap-2" href={featureHrefs[index] ?? localePath(lang, "/features#feature-breakdown")}>
          {feature.data.cta}
          {/* <span aria-hidden="true">→</span> */}
          <ArrowRight size={16} class="transition-transform group-hover:translate-x-1.5" />
        </Button>
      </Card>
    ))
  }
</Section>
