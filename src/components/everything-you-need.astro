---
import { ArrowRight } from "@lucide/astro";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Title from "./ui/title.astro";
import Button from "./ui/button.astro";
import Section from "./ui/section.astro";
import { t, localePath, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const cardVariants = ["subtle", "default", "brand"] as const;

const features = [
  {
    title: t(lang, "everything.card.0.title"),
    body: t(lang, "everything.card.0.body"),
    badge: t(lang, "everything.card.0.badge"),
    cta: t(lang, "everything.card.0.cta"),
    href: localePath(lang, "/features#template-system"),
  },
  {
    title: t(lang, "everything.card.1.title"),
    body: t(lang, "everything.card.1.body"),
    badge: t(lang, "everything.card.1.badge"),
    cta: t(lang, "everything.card.1.cta"),
    href: localePath(lang, "/features#feature-breakdown"),
  },
  {
    title: t(lang, "everything.card.2.title"),
    body: t(lang, "everything.card.2.body"),
    badge: t(lang, "everything.card.2.badge"),
    cta: t(lang, "everything.card.2.cta"),
    href: localePath(lang, "/features#feature-breakdown"),
  },
  {
    title: t(lang, "everything.card.3.title"),
    body: t(lang, "everything.card.3.body"),
    badge: t(lang, "everything.card.3.badge"),
    cta: t(lang, "everything.card.3.cta"),
    href: localePath(lang, "/features#feature-breakdown"),
  },
  {
    title: t(lang, "everything.card.4.title"),
    body: t(lang, "everything.card.4.body"),
    badge: t(lang, "everything.card.4.badge"),
    cta: t(lang, "everything.card.4.cta"),
    href: localePath(lang, "/features#feature-breakdown"),
  },
  {
    title: t(lang, "everything.card.5.title"),
    body: t(lang, "everything.card.5.body"),
    badge: t(lang, "everything.card.5.badge"),
    cta: t(lang, "everything.card.5.cta"),
    href: localePath(lang, "/features#feature-breakdown"),
  },
];
---

<Section
  monoTitle={t(lang, "everything.monoTitle")}
  title={t(lang, "everything.title")}
  description={t(lang, "everything.description")}
  contentClass="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
>
  {
    features.map((feature, index) => (
      <Card variant={cardVariants[index % cardVariants.length]} shadow="none" class="relative overflow-hidden">
        <MonoTitle>{feature.badge}</MonoTitle>
        <Title level={3} class="mt-4">
          {feature.title}
        </Title>
        <p class="mt-3 text-sm text-(--muted-text)">{feature.body}</p>
        <Button variant="primary" size="sm" class="group mt-6 flex items-center gap-2" href={feature.href}>
          {feature.cta}
          {/* <span aria-hidden="true">→</span> */}
          <ArrowRight size={16} class="transition-transform group-hover:translate-x-1.5" />
        </Button>
      </Card>
    ))
  }
</Section>
