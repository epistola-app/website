---
import { ArrowRight } from "@lucide/astro";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Title from "./ui/title.astro";
import Button from "./ui/button.astro";
import Section from "./ui/section.astro";
import { useTranslations } from "../i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

const { t, locale } = useTranslations(Astro);
const everythingYouNeed = t("everythingYouNeed");

const cardVariants = ["subtle", "default", "brand"] as const;

const featureLinks = [
  "/features#template-system",
  "/features#feature-breakdown",
  "/features#feature-breakdown",
  "/features#feature-breakdown",
  "/features#feature-breakdown",
  "/features#feature-breakdown",
];
---

<Section
  monoTitle={everythingYouNeed.monoTitle}
  title={everythingYouNeed.title}
  description={everythingYouNeed.description}
  contentClass="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
>
  {
    everythingYouNeed.features.map((feature, index) => (
      <Card variant={cardVariants[index % cardVariants.length]} shadow="none" class="relative overflow-hidden">
        <MonoTitle>{feature.badge}</MonoTitle>
        <Title level={3} class="mt-4">
          {feature.title}
        </Title>
        <p class="mt-3 text-sm text-(--muted-text)">{feature.body}</p>
        <Button variant="primary" size="sm" class="group mt-6 flex items-center gap-2" href={getRelativeLocaleUrl(locale, featureLinks[index])}>
          {everythingYouNeed.learnMore}
          <ArrowRight size={16} class="transition-transform group-hover:translate-x-1.5" />
        </Button>
      </Card>
    ))
  }
</Section>
