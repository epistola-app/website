---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const allProduct = await getCollection("product");
const detailSections = filterDataByLocale(allProduct, lang, "feature-section");
---

<Section
  id="feature-breakdown"
  monoTitle={t(lang, "features.monoTitle")}
  title={t(lang, "features.title")}
  description={t(lang, "features.description")}
  contentClass="space-y-8"
>
  {
    detailSections.map((section) => (
      <Card variant="default" padding="lg">
        <MonoTitle>{section.data.badge}</MonoTitle>
        <Title level={3} class="mt-3">
          {section.data.title}
        </Title>
        <ul class="mt-4 space-y-2 text-sm text-[var(--muted-text)]">
          {section.data.body.map((item: string) => (
            <li class="flex gap-3">
              <span class="mt-[6px] h-1.5 w-1.5 rounded-full bg-[var(--color-peach-paper-accent)]" aria-hidden="true" />
              <span class="flex-1">{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    ))
  }
</Section>
