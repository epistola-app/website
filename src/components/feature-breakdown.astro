---
import { useTranslations } from "../i18n";
import Card from "./ui/card.astro";
import MonoTitle from "./ui/mono-title.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";

const { t } = useTranslations(Astro);
const detail = t("features").featureBreakdown;
---

<Section
  id="feature-breakdown"
  monoTitle={detail.monoTitle}
  title={detail.title}
  description={detail.description}
  contentClass="space-y-8"
>
  {
    detail.sections.map((section) => (
      <Card variant="default" padding="lg">
        <MonoTitle>{section.badge}</MonoTitle>
        <Title level={3} class="mt-3">
          {section.title}
        </Title>
        <ul class="mt-4 space-y-2 text-sm text-(--muted-text)">
          {section.body.map((item) => (
            <li class="flex gap-3">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-(--color-peach-paper-accent)" aria-hidden="true" />
              <span class="flex-1">{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    ))
  }
</Section>
