---
import Button from "./ui/button.astro";
import Card from "./ui/card.astro";
import Title from "./ui/title.astro";
---

<section class="py-20">
  <Card variant="brand" radius="3xl" padding="none" shadow="lg" class="mx-auto max-w-3xl p-10 text-center">
    <p class="eyebrow">Newsletter</p>
    <Title level={2} class="mt-4"> Operational patterns from document-heavy teams. </Title>
    <p class="mt-4 text-sm text-[var(--muted-text)]">
      Monthly insights on governance, compliance, and automation. No noise.
    </p>
    <form class="mt-8 flex flex-col gap-4 sm:flex-row">
      <label class="relative flex-1">
        <span class="sr-only">Email</span>
        <input
          type="email"
          required
          placeholder="you@company.com"
          class="w-full rounded-2xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-5 py-4 text-sm font-medium text-[var(--color-peach-paper-heading)] placeholder:text-[var(--color-peach-paper-chip-text)] focus:border-[var(--color-peach-paper-border-strong)] focus:outline-none"
        />
      </label>
      <Button type="submit" variant="primary" size="md" class="w-full sm:w-auto">Subscribe</Button>
    </form>
    <p class="mt-4 text-xs text-[var(--color-peach-paper-chip-text)]">
      By subscribing you agree to receive Epistola updates. You can unsubscribe anytime.
    </p>
  </Card>
</section>
