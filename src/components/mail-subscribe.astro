---

---

<section class="relative py-20 md:py-28 overflow-hidden bg-accent-light/20">
  <div
    class="absolute inset-0 opacity-30"
    style="
              background-image: repeating-linear-gradient(
                  0deg,
                  rgba(5, 94, 104, 0.08) 0 1px,
                  transparent 1px 20px
                ),
                repeating-linear-gradient(
                  90deg,
                  rgba(5, 94, 104, 0.08) 0 1px,
                  transparent 1px 20px
                );
            "
  >
  </div>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-2xl mx-auto text-center">
      <div
        class="inline-flex items-center justify-center w-16 h-16 mb-6 bg-accent-teal/10 dark:bg-accent-teal/20 rounded-2xl"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-mail w-8 h-8 text-accent-teal dark:text-accent-light"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </div>
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 text-accent-dark dark:text-accent-light"
      >
        Stay in the loop
      </h2>
      <p
        class="text-lg md:text-xl text-accent-dark/70 dark:text-accent-light mb-10 font-light max-w-xl mx-auto"
      >
        Get the latest updates, product news, and exclusive insights delivered
        straight to your inbox.
      </p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
        <div class="flex-1 relative">
          <input
            type="email"
            placeholder="Enter your email"
            class="w-full px-6 py-4 pl-12 bg-white dark:bg-accent-dark border-2 border-accent-dark/10 dark:border-accent-light/20 rounded-lg text-accent-dark dark:text-accent-light placeholder-accent-dark/40 dark:placeholder-accent-light/40 focus:outline-none focus:border-accent-teal dark:focus:border-accent-green transition-all font-medium"
            required=""
            value=""
          /><svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-mail absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-accent-dark/40 dark:text-accent-light/40"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <button
          type="submit"
          class="px-8 py-4 bg-black dark:bg-white text-white dark:text-black rounded-lg font-semibold hover:bg-black/90 dark:hover:bg-white/90 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed shadow-lg hover:shadow-xl"
          tabindex="0"
        >
          Subscribe<svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-arrow-right w-5 h-5"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </button>
      </form>
      <p class="mt-6 text-sm text-accent-dark/60 dark:text-accent-light/60">
        No spam. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>
