---
import Button from "./ui/button.astro";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
---

<Section
  monoTitle={t(lang, "newsletter.monoTitle")}
  title={t(lang, "newsletter.title")}
  description={t(lang, "newsletter.description")}
  contentClass="grid grid-cols-1 lg:grid-cols-6"
>
  <Card variant="brand" padding="none" shadow="none" class="p-10 text-center lg:col-start-2 lg:col-span-4">
    <form class="mt-8 flex flex-col gap-4 sm:flex-row">
      <label class="relative flex-1">
        <span class="sr-only">{t(lang, "newsletter.form.email.label")}</span>
        <input
          type="email"
          autocomplete="email"
          required
          placeholder={t(lang, "newsletter.form.email.placeholder")}
          class="w-full rounded-none border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-5 py-2 text-sm font-medium text-[var(--color-peach-paper-heading)] placeholder:text-[var(--color-peach-paper-chip-text)] focus:border-[var(--color-peach-paper-border-strong)] focus:outline-none"
        />
      </label>
      <Button type="submit" variant="primary" size="md" class="w-full sm:w-auto">{t(lang, "newsletter.form.submit")}</Button>
    </form>
    <p class="mt-4 text-xs text-[var(--color-peach-paper-chip-text)]">
      {t(lang, "newsletter.form.disclaimer")}
    </p>
  </Card>
</Section>
