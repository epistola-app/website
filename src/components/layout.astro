---
import "../styles/global.css";
import Header from "./header.astro";
import Footer from "./footer.astro";
import { SITE, OG_TYPES, URLS, type OpenGraphProps, getAbsoluteURL } from "../lib/URL-helpers";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  og?: OpenGraphProps;
}

const {
  title = SITE.DEFAULT_TITLE,
  description = SITE.DEFAULT_DESCRIPTION,
  image,
  og = {},
} = Astro.props as Props;

const ogTitle = og.title || title;
const ogDescription = og.description || description;
const ogImage = og.image || image || SITE.DEFAULT_IMAGE;
const ogType = og.type || OG_TYPES.WEBSITE;
const ogUrl = og.url || Astro.url.href;

const absoluteImageUrl = ogImage.startsWith("http") ? ogImage : getAbsoluteURL(ogImage);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/logo.svg" />
    
    <link rel="canonical" href={ogUrl} />
    
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.NAME} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:locale" content={SITE.LOCALE} />
    <meta property="og:image" content={absoluteImageUrl} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.TWITTER_HANDLE} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={absoluteImageUrl} />
    
    {ogType === OG_TYPES.ARTICLE && og.article && (
      <>
        {og.article.author && <meta property="article:author" content={og.article.author} />}
        {og.article.publishedTime && <meta property="article:published_time" content={og.article.publishedTime.toISOString()} />}
        {og.article.modifiedTime && <meta property="article:modified_time" content={og.article.modifiedTime.toISOString()} />}
        {og.article.section && <meta property="article:section" content={og.article.section} />}
        {og.article.tags?.map(tag => <meta property="article:tag" content={tag} />)}
      </>
    )}
    
    <meta name="theme-color" content={SITE.THEME_COLOR} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'none';
                     script-src 'self' 'unsafe-inline';
                     style-src 'self' 'unsafe-inline';
                     font-src 'self';
                     img-src 'self';
                     connect-src 'self';
                     form-action 'self';
                     base-uri 'self'"
    />
    <!-- Fonts are self-hosted, loaded via @font-face in global.css -->
    <script is:inline>
      (() => {
        const storageKey = "epistola-theme";
        const root = document.documentElement;
        const prefersDarkQuery = window.matchMedia("(prefers-color-scheme: dark)");
        const moonPath = "M12 3.75A8.25 8.25 0 1 0 20.25 12 6.75 6.75 0 0 1 12 3.75z";
        const sunPath =
          "M12 3v1.5m0 15V21m8.485-8.485H19m-14 0H3m15.364 6.364-1.06-1.06M6.697 6.697 5.636 5.636m12.728 0-1.06 1.06M6.697 17.303l-1.06 1.06M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z";

        const getStoredTheme = () => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const storeTheme = (theme) => {
          try {
            window.localStorage.setItem(storageKey, theme);
          } catch {
            // Ignore storage write failures
          }
        };

        const getSystemTheme = () => (prefersDarkQuery.matches ? "dark" : "light");

        const updateToggleUI = (theme) => {
          const isDark = theme === "dark";

          document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
            toggle.setAttribute("aria-pressed", String(isDark));
            const srLabel = toggle.querySelector("[data-theme-toggle-label]");
            if (srLabel) {
              srLabel.textContent = isDark ? "Switch to light theme" : "Switch to dark theme";
            }

            const state = toggle.querySelector("[data-theme-toggle-state]");
            if (state) {
              state.textContent = isDark ? "Dark" : "Light";
            }
          });

          document.querySelectorAll("[data-theme-toggle-pill]").forEach((pill) => {
            pill.style.transform = isDark ? "translateX(24px)" : "translateX(0)";
          });

          document.querySelectorAll("[data-theme-toggle-icon-path]").forEach((iconPath) => {
            iconPath.setAttribute("d", isDark ? sunPath : moonPath);
          });
        };

        const applyTheme = (theme, persist = false) => {
          root.dataset.theme = theme;
          if (persist) {
            storeTheme(theme);
          }
          updateToggleUI(theme);
        };

        const resolveTheme = () => getStoredTheme() || getSystemTheme();

        root.dataset.theme = resolveTheme();

        const toggleTheme = () => {
          const currentTheme = root.dataset.theme || resolveTheme();
          const nextTheme = currentTheme === "dark" ? "light" : "dark";
          applyTheme(nextTheme, true);
        };

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) {
            return;
          }

          const toggle = event.target.closest("[data-theme-toggle]");
          if (!toggle) {
            return;
          }

          event.preventDefault();
          toggleTheme();
        });

        const syncThemeFromPreference = (event) => {
          if (!getStoredTheme()) {
            applyTheme(event.matches ? "dark" : "light");
          }
        };

        if (typeof prefersDarkQuery.addEventListener === "function") {
          prefersDarkQuery.addEventListener("change", syncThemeFromPreference);
        } else if (typeof prefersDarkQuery.addListener === "function") {
          prefersDarkQuery.addListener(syncThemeFromPreference);
        }

        const syncThemeUI = () => {
          updateToggleUI(root.dataset.theme || resolveTheme());
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", syncThemeUI, {
            once: true,
          });
        } else {
          syncThemeUI();
        }

        document.addEventListener("astro:page-load", syncThemeUI);
      })();
    </script>
  </head>
  <body class="font-sans antialiased flex flex-col min-h-screen overflow-x-hidden">
    <Header />
    <main class="relative z-10 flex-1 bg-[var(--color-peach-paper-surface-soft)]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
