---
import Button from "./ui/button.astro";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import SuiteDemoButton from "./buttons/suite-demo-button.astro";
import { URLS } from "../lib/URL-helpers";
---

<Section
  monoTitle="/ Next step"
  title="Ready to plug Epistola into your product?"
  description="We’ll review your templates, map the Common Ground payloads, and help you expose a render endpoint your orchestrator can call."
  contentClass="grid grid-cols-1 lg:grid-cols-6"
>
  <Card variant="brand" shadow="none" padding="none" class="p-8 md:p-10 lg:col-start-2 lg:col-span-4">
    <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
      <div class="text-left">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-peach-paper-chip-text)]">
          What happens next
        </p>
        <p class="mt-3 text-sm text-[var(--muted-text)]">30-minute architecture review and template fit check.</p>
        <p class="mt-2 text-sm text-[var(--muted-text)]">Concrete rollout plan tailored to your orchestrator stack.</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row md:flex-col md:items-stretch">
        <SuiteDemoButton />
        <Button href="/pricing" variant="secondary" size="md">Review plans</Button>
      </div>
    </div>
  </Card>
</Section>
