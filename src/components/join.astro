---

---

<section class="relative py-20 overflow-hidden bg-white">
  <div
    class="absolute inset-0 z-0"
    style="
              background: #ffffff;
              background-image: radial-gradient(
                circle at top right,
                rgba(255, 140, 60, 0.5),
                transparent 70%
              );
              filter: blur(80px);
              background-repeat: no-repeat;
            "
  >
  </div>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto">
      <h2
        class="text-5xl md:text-6xl lg:text-7xl font-black mb-8 text-accent-dark dark:text-accent-light leading-tight tracking-tight"
      >
        Ready to launch your SaaS?
      </h2>
      <p
        class="text-xl md:text-2xl text-accent-dark/80 dark:text-accent-light/80 mb-10 font-light leading-relaxed"
      >
        Join thousands of companies using our template to build their landing
        pages. Start your journey today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/register"
          class="px-8 py-4 bg-black dark:bg-white text-white dark:text-black rounded-lg font-semibold text-lg hover:bg-black/90 dark:hover:bg-white/90 transition-all"
          tabindex="0">Get Started Free</a
        ><a
          href="/pricing"
          class="px-8 py-4 bg-white dark:bg-accent-dark text-black dark:text-white border border-black/20 dark:border-white/20 rounded-lg font-semibold text-lg hover:bg-gray-50 dark:hover:bg-accent-dark/80 transition-all"
          tabindex="0">View Pricing</a
        >
      </div>
    </div>
  </div>
</section>
