---
import { getLocaleUrl, useTranslations, type Locale } from "../i18n";

const currentPath = Astro.url.pathname;
const currentLocale = Astro.currentLocale || "en";
const { t } = useTranslations(Astro);
const common = t("common");

const locales = [
  { code: "en", label: "English", flag: "🇬🇧" },
  { code: "nl", label: "Nederlands", flag: "🇳🇱" },
];

const otherLocales = locales.filter((l) => l.code !== currentLocale);
---

<div class="relative">
  <div class="flex items-center gap-2">
    {
      otherLocales.map((locale) => (
        <a
          href={getLocaleUrl(currentPath, locale.code as Locale)}
          class="flex items-center gap-1.5 px-2 py-1 text-sm font-medium text-(--color-peach-paper-copy) transition hover:text-(--color-peach-paper-heading)"
          aria-label={common.switchToLanguage.replace("{language}", locale.label)}
        >
          <span>{locale.flag}</span>
          <span class="inline">{locale.label}</span>
        </a>
      ))
    }
  </div>
</div>
