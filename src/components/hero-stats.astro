---
import Card from "./ui/card.astro";

const stats = [
  {
    value: "200+",
    label: "Template versions per variant",
  },
  {
    value: "50–200ms",
    label: "Render latency",
  },
  {
    value: "Multi-tenant",
    label: "Role & environment isolation",
  },
];
---

<section class="py-20 row-span-2">
  <div class="container mx-auto grid gap-8 lg:grid-cols-3 justify-items-center w-full">
    {
      stats.map((stat) => (
        <Card class="text-center w-full" variant="subtle" padding="md" shadow="none">
          <p class="text-2xl font-heading md:text-3xl font-semibold text-(--color-peach-paper-accent)">{stat.value}</p>
          <p class="mt-1 text-sm text-(--muted-text)">{stat.label}</p>
        </Card>
      ))
    }
  </div>
</section>
