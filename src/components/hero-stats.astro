---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import { filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const stats = filterDataByLocale(items, lang, "hero-stats");
---

<section class="py-20 row-span-2">
  <div class="container mx-auto grid gap-8 lg:grid-cols-3 justify-items-center w-full">
    {
      stats.map((stat) => (
        <Card class="text-center w-full" variant="subtle" padding="md" shadow="none">
          <p class="text-2xl font-heading md:text-3xl font-semibold text-(--color-peach-paper-accent)">{stat.data.value}</p>
          <p class="mt-1 text-sm text-(--muted-text)">{stat.data.label}</p>
        </Card>
      ))
    }
  </div>
</section>
