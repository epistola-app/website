---
import Button from "./ui/button.astro";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import Title from "./ui/title.astro";

const tiers = [
  {
    name: "Community",
    price: "Free",
    cadence: "open source",
    description: "Self-host Epistola under the AGPL license with community support.",
    features: ["Full editor + renderer", "Common Ground adapters", "Docker/Kubernetes images"],
    cardVariant: "subtle",
  },
  {
    name: "Support",
    price: "€1.2k",
    cadence: "per month",
    description: "Commercial support for teams running Epistola themselves.",
    features: ["Priority fixes", "Upgrade guidance", "Architecture reviews"],
    highlighted: true,
    cardVariant: "brand",
  },
  {
    name: "Managed",
    price: "Custom",
    cadence: "per month",
    description: "Hosted Epistola with SLAs, monitoring, and dedicated environments.",
    features: ["SLA-backed hosting", "Custom connectors", "Dedicated success engineer"],
    cardVariant: "default",
  },
];
---

<Section monoTitle="/ Pricing plans" title="Choose the support level you need." contentClass="grid gap-6 md:grid-cols-3">
  {
    tiers.map((tier) => (
      <Card
        variant={tier.cardVariant}
        padding="lg"
        shadow="none"
        class={`flex flex-col ${tier.highlighted ? "ring-2 ring-[var(--color-peach-paper-accent)]" : ""}`}
      >
        <div class="flex items-start justify-between">
          <div>
            <p class="text-sm font-semibold text-[var(--color-peach-paper-chip-text)]">{tier.cadence}</p>
            <Title level={3} class="mt-2 text-3xl">
              {tier.name}
            </Title>
          </div>
          <p class="text-3xl font-semibold text-[var(--color-peach-paper-accent)]">{tier.price}</p>
        </div>
        <p class="mt-4 text-sm text-[var(--muted-text)]">{tier.description}</p>
        <ul class="mt-6 space-y-3 text-sm text-[var(--color-peach-paper-copy)]">
          {tier.features.map((feature) => (
            <li class="flex items-center gap-2">
              <span class="h-2 w-2 bg-[var(--color-peach-paper-accent)]" />
              {feature}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <Button
            href={
              tier.name === "Community"
                ? "https://github.com/epistola-app"
                : tier.highlighted
                  ? "https://demo.epistola.app"
                  : "/register"
            }
            variant={tier.highlighted ? "primary" : tier.name === "Community" ? "link" : "secondary"}
            size="md"
            class={tier.name === "Community" ? "w-full justify-start sm:justify-center" : "w-full justify-center"}
            external={tier.name === "Community" || tier.highlighted}
          >
            {tier.name === "Community" ? "View on GitHub" : tier.highlighted ? "Open demo" : "Talk to sales"}
          </Button>
        </div>
      </Card>
    ))
  }
</Section>
