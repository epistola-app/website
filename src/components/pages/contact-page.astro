---
import { Mail } from "@lucide/astro";
import { useTranslations } from "../../i18n";
import { EMAILS } from "../../lib/URL-helpers";
import ContactForm from "../contact-form.astro";
import Layout from "../layout.astro";
import Card from "../ui/card.astro";
import Title from "../ui/title.astro";

const { t } = useTranslations(Astro);
const contact = t("contact");
---

<Layout title={contact.page.title} description={contact.page.description}>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <p class="eyebrow">{contact.hero.eyebrow}</p>
      <Title level={1} class="mt-6">{contact.hero.title}</Title>
      <p class="mt-4 text-lg text-(--muted-text)">{contact.hero.description}</p>
    </div>
  </section>

  <section class="pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid grid-cols-5">
        <Card variant="brand" shadow="none" padding="md" radius="none" class="col-start-2 col-end-5">
          <ContactForm />
        </Card>
      </div>

      <div class="mx-auto mt-8 max-w-2xl text-center text-sm text-(--color-peach-paper-chip-text)">
        <p class="flex items-center justify-center gap-2">
          <Mail class="h-4 w-4" />
          {contact.directEmail.prefix}
          <a href={EMAILS.HELLO} class="text-(--color-peach-paper-accent) hover:underline"> sander@epistola.app </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
