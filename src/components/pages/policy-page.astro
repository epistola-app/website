---
import Layout from "../layout.astro";
import Title from "../ui/title.astro";

interface SectionItem {
  title: string;
  body: string;
}

interface ContactContent {
  title: string;
  prefix: string;
  suffix?: string;
  email: string;
  emailHref: string;
}

interface Props {
  pageTitle: string;
  pageDescription: string;
  eyebrow: string;
  title: string;
  description?: string;
  sections: SectionItem[];
  contact: ContactContent;
}

const { pageTitle, pageDescription, eyebrow, title, description, sections, contact } = Astro.props as Props;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-3xl px-4">
      <p class="eyebrow">{eyebrow}</p>
      <Title level={1} class="mt-4">{title}</Title>
      {description ? <p class="mt-4 text-lg text-(--muted-text)">{description}</p> : null}
      <div class="mt-10 space-y-10 text-(--color-peach-paper-copy)">
        {
          sections.map((section) => (
            <section>
              <Title level={2}>{section.title}</Title>
              <p class="mt-3">{section.body}</p>
            </section>
          ))
        }
        <section>
          <Title level={2}>{contact.title}</Title>
          <p class="mt-3">
            {contact.prefix}
            <a class="underline hover:text-(--color-peach-paper-accent)" href={contact.emailHref}>{contact.email}</a>{
              contact.suffix ? ` ${contact.suffix}` : "."
            }
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
