---
import { useTranslations } from "../i18n";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";

const { t } = useTranslations(Astro);
const testimonialsData = t("testimonials");
---

<Section
  monoTitle={testimonialsData.monoTitle}
  title={testimonialsData.title}
  description={testimonialsData.description}
  contentClass="grid gap-6 md:grid-cols-3"
>
  {
    testimonialsData.items.map((item) => (
      <Card variant="subtle" shadow="none" class="flex flex-col gap-4 text-left">
        <p class="text-base text-(--color-peach-paper-heading)">"{item.quote}"</p>
        <div class="mt-auto pt-6">
          <p class="text-sm font-semibold text-(--color-peach-paper-heading)">{item.author}</p>
          <p class="text-xs mt-auto uppercase tracking-[0.12em] text-(--color-peach-paper-chip-text)">{item.role}</p>
        </div>
      </Card>
    ))
  }
</Section>
