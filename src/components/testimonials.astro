---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";

const cardVariants = ["subtle", "default", "brand"] as const;

const testimonials = [
  {
    quote:
      "Epistola is the simplest part of our case platform. We send JSON, we get flawless PDF/A output back. That focus is refreshing.",
    name: "Katinka Laagland",
    role: "Product Owner, GZAC",
  },
  {
    quote: "Common Ground compliance was non‑negotiable. Epistola spoke the same language from day one.",
    name: "Jeroen van Lier",
    role: "Solution Architect, Gemeente Breda",
  },
  {
    quote:
      "We keep workflows in Valtimo and let Epistola handle rendering. Separation of concerns, just like it should be.",
    name: "Sara Dijkstra",
    role: "Lead Developer, Valtimo Ecosystem",
  },
];
---

<Section
  monoTitle="/ Customer impact"
  title="Trusted with high-stakes documents."
  contentClass="grid gap-6 md:grid-cols-3"
>
  {
    testimonials.map((testimonial) => (
      <Card variant="subtle" shadow="none" class="flex flex-col text-left">
        <p class="text-base text-[var(--color-peach-paper-heading)]">“{testimonial.quote}”</p>
        <div class="mt-6">
          <p class="text-sm font-semibold text-[var(--color-peach-paper-heading)]">{testimonial.name}</p>
          <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
            {testimonial.role}
          </p>
        </div>
      </Card>
    ))
  }
</Section>
