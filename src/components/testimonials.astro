---
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import { t, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const cardVariants = ["subtle", "default", "brand"] as const;

const testimonials = [
  {
    quote: t(lang, "testimonials.0.quote"),
    name: t(lang, "testimonials.0.name"),
    role: t(lang, "testimonials.0.role"),
  },
  {
    quote: t(lang, "testimonials.1.quote"),
    name: t(lang, "testimonials.1.name"),
    role: t(lang, "testimonials.1.role"),
  },
  {
    quote: t(lang, "testimonials.2.quote"),
    name: t(lang, "testimonials.2.name"),
    role: t(lang, "testimonials.2.role"),
  },
];
---

<Section
  monoTitle={t(lang, "testimonials.monoTitle")}
  title={t(lang, "testimonials.title")}
  contentClass="grid gap-6 md:grid-cols-3"
>
  {
    testimonials.map((testimonial) => (
      <Card variant="subtle" shadow="none" class="flex flex-col text-left">
        <p class="text-base text-[var(--color-peach-paper-heading)]">"{testimonial.quote}"</p>
        <div class="mt-6">
          <p class="text-sm font-semibold text-[var(--color-peach-paper-heading)]">{testimonial.name}</p>
          <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
            {testimonial.role}
          </p>
        </div>
      </Card>
    ))
  }
</Section>
