---
import { getCollection } from "astro:content";
import Card from "./ui/card.astro";
import Section from "./ui/section.astro";
import { t, filterByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("pages");
const testimonials = filterByLocale(items, lang, "testimonial");
---

<Section
  monoTitle={t(lang, "testimonials.monoTitle")}
  title={t(lang, "testimonials.title")}
  contentClass="grid gap-6 md:grid-cols-3"
>
  {
    testimonials.map((testimonial) => (
      <Card variant="subtle" shadow="none" class="flex flex-col text-left">
        <p class="text-base text-[var(--color-peach-paper-heading)]">"{testimonial.data.quote}"</p>
        <div class="mt-6">
          <p class="text-sm font-semibold text-[var(--color-peach-paper-heading)]">{testimonial.data.name}</p>
          <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-peach-paper-chip-text)]">
            {testimonial.data.role}
          </p>
        </div>
      </Card>
    ))
  }
</Section>
