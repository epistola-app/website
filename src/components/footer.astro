---
import { URLS, EMAILS } from "../lib/URL-helpers";
import { t, localePath, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const logoHref = localePath(lang, "/");

const footerLinks = [
  {
    title: t(lang, "footer.section.product"),
    links: [
      { href: localePath(lang, "/features"), text: t(lang, "footer.link.platform") },
      { href: localePath(lang, "/integrations"), text: t(lang, "footer.link.integrations") },
      { href: localePath(lang, "/pricing"), text: t(lang, "footer.link.pricing") },
      { href: localePath(lang, "/about"), text: t(lang, "footer.link.about") },
      { href: localePath(lang, "/contact"), text: t(lang, "footer.link.contact") },
    ],
  },
  {
    title: t(lang, "footer.section.resources"),
    links: [
      { href: localePath(lang, "/docs"), text: t(lang, "footer.link.documentation") },
      { href: localePath(lang, "/blog"), text: t(lang, "footer.link.blog") },
      {
        href: URLS.GITHUB,
        text: t(lang, "footer.link.github"),
        external: true,
      },
    ],
  },
  {
    title: t(lang, "footer.section.trust"),
    links: [
      { href: localePath(lang, "/security"), text: t(lang, "footer.link.security") },
      { href: localePath(lang, "/privacy"), text: t(lang, "footer.link.privacy") },
      { href: localePath(lang, "/terms"), text: t(lang, "footer.link.terms") },
    ],
  },
];
---

<footer class="footer-reveal mt-auto border-t border-[var(--color-peach-paper-nav-border)] text-[var(--color-peach-paper-copy)] lg:sticky lg:bottom-0">
  <div class="footer-reveal__inner container mx-auto px-4 py-14 lg:py-16">
    <div class="grid gap-10 border-b border-[var(--color-peach-paper-border)] pb-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href={logoHref} class="inline-flex items-center gap-3">
          <img src="/logo.svg" alt={t(lang, "footer.logo.alt")} class="h-10 w-10" />
          <div class="flex flex-col">
            <span class="text-base font-semibold tracking-tight text-[var(--color-peach-paper-heading)]">Epistola</span>
            <span class="text-[10px] uppercase tracking-[0.16em] text-[var(--color-peach-paper-copy)]">{t(lang, "footer.logo.subtitle")}</span>
          </div>
        </a>

        <p class="mt-4 max-w-sm text-sm leading-6 text-[var(--color-peach-paper-copy)]">
          {t(lang, "footer.description")}
        </p>

        <div class="mt-6 flex flex-col gap-2 text-sm">
          <a
            href={EMAILS.HELLO}
            class="transition hover:text-[var(--color-peach-paper-accent)]"
          >
            sander@epistola.app
          </a>
        </div>
      </div>

      <div class="md:col-span-3 grid gap-8 sm:grid-cols-3">
        {
          footerLinks.map((section) => (
            <div>
              <p class="text-sm font-semibold text-[var(--color-peach-paper-heading)]">
                {section.title}
              </p>
              <ul class="mt-4 space-y-2 text-sm text-[var(--color-peach-paper-copy)]">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="transition hover:text-[var(--color-peach-paper-heading)]"
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noreferrer" : undefined}
                    >
                      {link.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-6 flex flex-col gap-3 text-xs text-[var(--color-peach-paper-copy)] sm:flex-row sm:items-center sm:justify-between">
      <p>{t(lang, "footer.copyright", { year: String(new Date().getFullYear()) })}</p>
      <div class="flex flex-wrap gap-4">
        <a class="transition hover:text-[var(--color-peach-paper-heading)]" href={localePath(lang, "/privacy")}>{t(lang, "footer.bottomLink.privacy")}</a>
        <a class="transition hover:text-[var(--color-peach-paper-heading)]" href={localePath(lang, "/terms")}>{t(lang, "footer.bottomLink.terms")}</a>
        <a class="transition hover:text-[var(--color-peach-paper-heading)]" href={localePath(lang, "/security")}>{t(lang, "footer.bottomLink.security")}</a>
      </div>
    </div>
  </div>
</footer>
