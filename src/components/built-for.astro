---
import { getCollection } from "astro:content";
import Section from "./ui/section.astro";
import { t, filterDataByLocale, type Locale, DEFAULT_LOCALE } from "../i18n";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const items = await getCollection("homepage");
const builtForItems = filterDataByLocale(items, lang, "built-for");

const workflowSteps = builtForItems.map((item, index) => ({
  title: item.data.title,
  description: item.data.description,
  inactiveLabel: item.data.inactiveLabel,
  isActive: index === 0,
  card: item.data.card,
  stages: item.data.stages,
}));

const activeLabel = t(lang, "builtFor.stepStatus.active");
---

<Section
  monoTitle={t(lang, "builtFor.monoTitle")}
  title={t(lang, "builtFor.title")}
  description={t(lang, "builtFor.description")}
  contentClass="grid gap-6 lg:grid-cols-2"
  data-built-for
  data-active-label={activeLabel}
>
  <div class="flex flex-col gap-4">
    {
      workflowSteps.map((step, index) => (
        <button
          type="button"
          data-step-button
          data-step-index={index}
          data-inactive-label={step.inactiveLabel}
          data-active={step.isActive ? "true" : "false"}
          class:list={{
            "flex w-full flex-col gap-2 border border-(--color-peach-paper-border) px-5 py-4 text-left transition": true,
            "opacity-70": true,
            "bg-(--color-peach-paper-chip-bg)": step.isActive,
            "text-(--color-peach-paper-copy)": true,
          }}
          aria-pressed={step.isActive ? "true" : "false"}
        >
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-[0.18em]">Step {index + 1}</span>
            <span class="text-xs font-semibold uppercase tracking-[0.16em]" data-step-status>
              {step.isActive ? activeLabel : step.inactiveLabel}
            </span>
          </div>
          <div>
            <p class="text-base font-semibold">{step.title}</p>
            <p class="mt-1 text-sm text-(--muted-text)">{step.description}</p>
          </div>
        </button>
      ))
    }
  </div>
  <div class="relative">
    {
      workflowSteps.map((step, index) => (
        <div
          class:list={{
            "relative bg-(--color-peach-paper-chip-bg) flex flex-col h-full gap-6 border border-(--color-peach-paper-border) px-6 py-6": true,
            hidden: !step.isActive,
          }}
          data-step-panel
          data-step-index={index}
          aria-hidden={step.isActive ? "false" : "true"}
        >
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.16em] text-(--color-peach-paper-chip-text)">
                {step.card.eyebrow}
              </p>
              <p class="text-lg font-semibold">{step.card.title}</p>
            </div>
            <span class="border min-w-32 text-center border-(--color-peach-paper-border) bg-(--color-peach-paper-chip-bg) px-3 py-1 text-xs font-semibold text-(--color-peach-paper-accent)">
              {step.card.badge}
            </span>
          </div>
          <ol class="flex flex-col grow justify-between">
            {step.stages.map((stage, stageIndex) => (
              <li
                class="flex items-start gap-4 transition-opacity duration-300"
                data-step-item
                data-step-item-index={stageIndex}
              >
                <span class="mt-1 flex h-7 w-7 items-center justify-center border border-(--color-peach-paper-border) text-xs font-semibold">
                  {stageIndex + 1}
                </span>
                <div>
                  <p class="text-sm font-semibold">{stage.label}</p>
                  <p class="text-sm text-(--muted-text)">{stage.detail}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      ))
    }
  </div>
</Section>

<script is:inline>
  const sections = document.querySelectorAll("[data-built-for]");

  const initSection = (section) => {
    const buttons = Array.from(section.querySelectorAll("[data-step-button]"));
    const panels = Array.from(section.querySelectorAll("[data-step-panel]"));
    const activeLabel = section.getAttribute("data-active-label") || "Active";

    if (!buttons.length || !panels.length) return;

    const setActive = (activeIndex, shouldAnimate = false) => {
      buttons.forEach((button, index) => {
        const isActive = index === activeIndex;
        const status = button.querySelector("[data-step-status]");
        const inactiveLabel = button.getAttribute("data-inactive-label") || "Next";

        button.classList.toggle("bg-[var(--color-peach-paper-chip-bg)]", isActive);
        button.classList.toggle("opacity-70", !isActive);
        button.setAttribute("aria-pressed", String(isActive));
        button.setAttribute("data-active", isActive ? "true" : "false");

        if (status) {
          status.textContent = isActive ? activeLabel : inactiveLabel;
        }
      });

      panels.forEach((panel, index) => {
        const isActive = index === activeIndex;
        panel.setAttribute("aria-hidden", String(!isActive));

        if (isActive) {
          panel.classList.remove("hidden");
          const items = Array.from(panel.querySelectorAll("[data-step-item]"));
          const totalStagger = 150;
          const stepDelay = items.length > 1 ? totalStagger / (items.length - 1) : 0;

          if (shouldAnimate) {
            items.forEach((item) => {
              item.classList.add("opacity-0");
              item.classList.remove("opacity-100");
              const itemIndex = Number(item.getAttribute("data-step-item-index")) || 0;
              item.style.transitionDelay = `${itemIndex * stepDelay}ms`;
            });

            requestAnimationFrame(() => {
              items.forEach((item) => {
                item.classList.add("opacity-100");
                item.classList.remove("opacity-0");
              });
            });
          } else {
            items.forEach((item) => {
              item.classList.add("opacity-100");
              item.classList.remove("opacity-0");
              item.style.transitionDelay = "0ms";
            });
          }
        } else {
          const items = Array.from(panel.querySelectorAll("[data-step-item]"));
          items.forEach((item) => {
            item.classList.add("opacity-0");
            item.classList.remove("opacity-100");
            item.style.transitionDelay = "0ms";
          });
          panel.classList.add("hidden");
        }
      });
    };

    const defaultIndex = Math.max(
      0,
      buttons.findIndex((button) => button.getAttribute("data-active") === "true"),
    );

    setActive(defaultIndex, false);

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => setActive(index, true));
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      sections.forEach(initSection);
    });
  } else {
    sections.forEach(initSection);
  }
</script>
