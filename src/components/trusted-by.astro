---

---

<section
  class="border-y border-[var(--color-peach-paper-border-soft)] py-12 [background-image:var(--gradient-peach-paper-soft)]"
>
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-4">
    <p
      class="text-center text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-peach-paper-copy)]"
    >
      Trusted in regulated industries
    </p>
    <div
      class="flex w-full flex-wrap items-center justify-center gap-8 opacity-80"
    >
      {
        [
          "Northwind Mutual",
          "Asteria Bank",
          "Linea Health",
          "Continuum Energy",
          "Cenith Legal",
          "Polaris",
        ].map((name) => (
          <div class="flex items-center justify-center rounded-2xl border border-[var(--color-peach-paper-border)] bg-[var(--color-peach-paper-chip-bg)] px-6 py-3 text-sm font-semibold tracking-[0.08em] text-[var(--color-peach-paper-copy)]">
            {name}
          </div>
        ))
      }
    </div>
  </div>
</section>
